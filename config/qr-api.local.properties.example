# Local-only QR API config used by TicketPdfService.
# This file is ignored by git (.gitignore).

qr.api.url=https://api.qrserver.com/v1/create-qr-code/

# Optional if you use RapidAPI endpoint instead of qrserver.
qr.api.key=
qr.api.host=
qr.api.logoUrl=

# Optional qrserver parameters
qr.api.size=280x280
qr.api.format=png
qr.api.ecc=L
qr.api.margin=1
qr.api.qzone=0
qr.api.color=255-0-0
qr.api.bgcolor=255-255-0
qr.api.charsetSource=UTF-8
qr.api.charsetTarget=UTF-8

# Debug/validation options
qr.api.debug=true
qr.api.strict=false
# optional absolute path override used when file is launched from another working directory
# qr.api.configPath=C:/Users/Khalil/Desktop/Studies/Semestre 2/Pi Dev/Java/config/qr-api.local.properties


