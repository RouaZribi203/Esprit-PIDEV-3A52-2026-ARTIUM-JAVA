<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>

<VBox xmlns="http://javafx.com/javafx/20.0.2"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.GlobalPlayerController"
      styleClass="global-player-root"
      alignment="BOTTOM_CENTER">

    <!-- Lyrics Panel (Hidden by default) -->
    <VBox fx:id="lyricsPanel" managed="false" visible="false"
          styleClass="global-player-lyrics-panel"
          spacing="10" alignment="CENTER"
          maxHeight="300" minHeight="200" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="15" right="20" bottom="15" left="20" />
        </padding>
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label fx:id="lyricsStatusLabel" text="Prêt à générer des paroles." styleClass="global-player-lyrics-status" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
            <Button fx:id="generateLyricsButton" text="Générer avec IA" onAction="#handleGenerateLyrics" styleClass="global-player-button-secondary" />
            <Button fx:id="copyLyricsButton" text="Copier" onAction="#handleCopyLyrics" styleClass="global-player-button-secondary" />
        </HBox>
        <TextArea fx:id="lyricsTextArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS" styleClass="global-player-lyrics-area" />
    </VBox>

    <HBox alignment="CENTER_LEFT" styleClass="global-player-bar">
        <padding>
            <Insets bottom="10" left="20" right="20" top="10" />
        </padding>

        <!-- LEFT: Cover + Track info — fixed width, no grow -->
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="global-player-track-block"
              minWidth="200" prefWidth="220" maxWidth="260" HBox.hgrow="NEVER">
            <StackPane styleClass="global-player-cover-frame"
                       minWidth="52" minHeight="52" maxWidth="52" maxHeight="52">
                <ImageView fx:id="coverImageView" fitHeight="44" fitWidth="44"
                           styleClass="global-player-cover" preserveRatio="true" />
            </StackPane>
            <VBox spacing="3" styleClass="global-player-track-info">
                <Label fx:id="titleLabel" styleClass="global-player-title"
                       text="Aucune piste en lecture" maxWidth="180" />
                <Label fx:id="artistLabel" styleClass="global-player-artist"
                       text="Artiste inconnu" maxWidth="180" />
            </VBox>
        </HBox>

        <!-- CENTER: fills all remaining space, controls + slider stacked -->
        <VBox alignment="CENTER" spacing="6" styleClass="global-player-center"
              HBox.hgrow="ALWAYS">

            <HBox alignment="CENTER" spacing="8" styleClass="global-player-controls">
                <Button mnemonicParsing="false" onAction="#handlePrevious"
                        styleClass="global-player-button" text="⏮"
                        minWidth="36" minHeight="36" maxWidth="36" maxHeight="36" />
                <Button fx:id="playPauseButton" mnemonicParsing="false" onAction="#handlePlayPause"
                        styleClass="global-player-playpause" text="▶"
                        minWidth="46" minHeight="46" maxWidth="46" maxHeight="46" />
                <Button mnemonicParsing="false" onAction="#handleNext"
                        styleClass="global-player-button" text="⏭"
                        minWidth="36" minHeight="36" maxWidth="36" maxHeight="36" />
            </HBox>

            <!-- Progress row: time label + slider in one HBox, no BorderPane -->
            <HBox alignment="CENTER" spacing="10" styleClass="global-player-progress-row"
                  minWidth="240" prefWidth="380" maxWidth="430">
                <Label fx:id="timeLabel" styleClass="global-player-time"
                       text="0:00 / 0:00" minWidth="72" maxWidth="72" />
                <Slider fx:id="progressSlider" max="1.0"
                        onMousePressed="#handleSeekStart"
                        onMouseReleased="#handleSeekEnd"
                        minWidth="150" prefWidth="300" maxWidth="340"
                        HBox.hgrow="ALWAYS" />
            </HBox>

        </VBox>

        <!-- RIGHT: Volume + Genre + Status — fixed width, no grow -->
        <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="global-player-right"
              minWidth="250" prefWidth="300" maxWidth="350" HBox.hgrow="NEVER">
              
            <!-- Lyrics Toggle -->
            <Button fx:id="lyricsToggleButton" mnemonicParsing="false" onAction="#handleToggleLyrics"
                    styleClass="global-player-button global-player-button-secondary" text="🎤"
                    minWidth="32" minHeight="32" maxWidth="32" maxHeight="32" />

            <HBox alignment="CENTER" spacing="8" styleClass="global-player-volume-box">
                <Button fx:id="muteButton" mnemonicParsing="false" onAction="#handleMute"
                        styleClass="global-player-button global-player-button-secondary" text="🔊"
                        minWidth="32" minHeight="32" maxWidth="32" maxHeight="32" />
                <Slider fx:id="volumeSlider" max="1.0" value="0.5"
                        minWidth="62" prefWidth="62" maxWidth="62" />
            </HBox>

            <VBox alignment="CENTER_RIGHT" spacing="5" styleClass="global-player-state"
                  minWidth="90">
                <Label fx:id="metaLabel" styleClass="global-player-meta" text="Genre: -" />
                <Label fx:id="statusLabel" styleClass="global-player-status" text="Prêt" />
            </VBox>
        </HBox>

    </HBox>
</VBox>
