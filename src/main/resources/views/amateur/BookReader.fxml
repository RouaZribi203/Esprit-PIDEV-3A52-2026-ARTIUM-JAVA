<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.amateur.BookReaderController">
    <top>
        <VBox spacing="8.0" styleClass="amateur-page-card">
            <padding>
                <Insets bottom="20.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <Label styleClass="page-title" text="Lecteur de livre" />
            <Label styleClass="page-subtitle" text="Structure du lecteur PDF amateur." wrapText="true" />
        </VBox>
    </top>
    <center>
        <VBox spacing="14.0" styleClass="amateur-page-card">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="0.0" />
            </padding>
            <StackPane minHeight="420.0" styleClass="empty-state-card">
                <Label text="Zone de rendu PDF" />
            </StackPane>
            <HBox spacing="10.0">
                <Button mnemonicParsing="false" text="Précédent" />
                <Button mnemonicParsing="false" text="Suivant" />
                <Label text="Page 1 / 1" />
            </HBox>
        </VBox>
    </center>
</BorderPane>

