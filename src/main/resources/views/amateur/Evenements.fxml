<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="amateur-events-page" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.amateur.EventsfrontController">
    <top>
        <VBox spacing="10.0" styleClass="amateur-events-hero">
            <padding>
                <Insets bottom="20.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="page-title" text="Découvrir Evènements" />
                    <Label styleClass="page-subtitle" text="Explorez les evenements disponibles et trouvez celui qui vous plait." />
                </VBox>
                <Button mnemonicParsing="false" styleClass="amateur-primary-pill" text="Event idea AI powered" />
            </HBox>

            <HBox spacing="8.0">
                <TextField fx:id="searchField" promptText="Rechercher par titre ou description" styleClass="amateur-search-field" HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#onSearchClick" styleClass="amateur-search-button" text="Search" />
            </HBox>

            <HBox spacing="18.0" styleClass="amateur-category-tabs">
                <ToggleButton fx:id="allTabButton" mnemonicParsing="false" onAction="#onAllTabClick" styleClass="amateur-tab-button" text="Tous" />
                <ToggleButton fx:id="expositionTabButton" mnemonicParsing="false" onAction="#onExpositionTabClick" styleClass="amateur-tab-button" text="Exposition" />
                <ToggleButton fx:id="concertTabButton" mnemonicParsing="false" onAction="#onConcertTabClick" styleClass="amateur-tab-button" text="Concert" />
                <ToggleButton fx:id="spectacleTabButton" mnemonicParsing="false" onAction="#onSpectacleTabClick" styleClass="amateur-tab-button" text="Spectacle" />
                <ToggleButton fx:id="conferenceTabButton" mnemonicParsing="false" onAction="#onConferenceTabClick" styleClass="amateur-tab-button" text="Conférence" />
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="14.0" styleClass="amateur-events-body">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="0.0" />
            </padding>

            <Label fx:id="emptyStateLabel" styleClass="section-subtitle" text="Aucun evenement disponible." visible="false" />

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="amateur-events-scroll" VBox.vgrow="ALWAYS">
                <FlowPane fx:id="eventsFlowPane" hgap="16.0" prefWrapLength="780.0" styleClass="amateur-events-flow" vgap="16.0">
                    <padding>
                        <Insets bottom="8.0" left="2.0" right="2.0" top="8.0" />
                    </padding>
                </FlowPane>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
