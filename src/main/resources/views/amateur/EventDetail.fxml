<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="controllers.amateur.EventDetailController" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1">
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="event-detail-scroll">
            <content>
                <VBox spacing="18.0" styleClass="event-detail-root">
                    <padding>
                        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
                    </padding>

                    <StackPane minHeight="260.0" styleClass="event-cover-box">
                        <ImageView fx:id="coverImageView" fitWidth="900.0" fitHeight="260.0" preserveRatio="true" />
                    </StackPane>

                    <VBox spacing="14.0" styleClass="amateur-page-card,event-detail-header-card">
                        <padding>
                            <Insets top="18.0" right="18.0" bottom="18.0" left="18.0" />
                        </padding>

                        <Label fx:id="titleLabel" styleClass="event-title" text="Evenement" wrapText="true" />

                        <HBox spacing="8.0">
                            <Label fx:id="typeLabel" styleClass="event-chip event-chip-type" text="Type" />
                            <Label fx:id="statusLabel" styleClass="event-chip event-chip-status" text="Statut" />
                        </HBox>

                        <Label text="Description" styleClass="event-description-title" />
                        <Label fx:id="descriptionLabel" styleClass="event-description" text="Description" wrapText="true" />

                        <GridPane hgap="18.0" vgap="8.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <Label styleClass="event-stat-label" text="Horaire debut" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <Label styleClass="event-stat-label" text="Horaire fin" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                            <Label styleClass="event-stat-label" text="Prix" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                            <Label styleClass="event-stat-label" text="Capacite" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                            <Label fx:id="dateDebutLabel" styleClass="event-stat-value" text="-" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                            <Label fx:id="dateFinLabel" styleClass="event-stat-value" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                            <Label fx:id="priceLabel" styleClass="event-stat-value event-price-value" text="-" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                            <Label fx:id="capacityLabel" styleClass="event-stat-value" text="-" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                        </GridPane>

                        <HBox spacing="8.0" alignment="CENTER_LEFT" styleClass="event-location-info">
                            <Label text="Galerie:" styleClass="event-location-label" />
                            <Label fx:id="galleryLabel" text="-" />
                            <Label fx:id="metaLabel" styleClass="page-caption" text="-" />
                        </HBox>
                    </VBox>

                    <VBox spacing="10.0" styleClass="amateur-page-card ticket-section-card">
                        <padding>
                            <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
                        </padding>

                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <Label text="Mes tickets" styleClass="ticket-section-title" />
                            <Label fx:id="ticketsCountLabel" styleClass="ticket-count-chip" text="0 ticket(s)" />
                            <StackPane HBox.hgrow="ALWAYS" />
                            <Button fx:id="buyTicketButton" text="Acheter ticket" onAction="#onBuyTicketClick" styleClass="ticket-action-primary" />
                            <Button fx:id="backButton" text="Retour" onAction="#onBackClick" styleClass="ticket-action-secondary" />
                        </HBox>

                        <Label fx:id="ticketsEmptyLabel" styleClass="page-caption" text="Aucun ticket achete pour cet evenement." />
                        <VBox fx:id="ticketsContainer" spacing="8.0" VBox.vgrow="ALWAYS" />
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>

