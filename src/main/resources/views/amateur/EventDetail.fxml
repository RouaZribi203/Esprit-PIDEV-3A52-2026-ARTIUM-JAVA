<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox spacing="8.0" styleClass="amateur-page-card">
            <padding>
                <Insets bottom="20.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <Label styleClass="page-title" text="Détail de l'évènement" />
            <Label styleClass="page-subtitle" text="Structure de la page détail évènement amateur." wrapText="true" />
        </VBox>
    </top>
    <center>
        <VBox spacing="14.0" styleClass="amateur-page-card">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="0.0" />
            </padding>
            <StackPane minHeight="240.0" styleClass="empty-state-card">
                <Label text="Couverture de l'évènement" />
            </StackPane>
            <HBox spacing="12.0">
                <Button mnemonicParsing="false" text="Acheter ticket" />
                <Button mnemonicParsing="false" text="Retour aux évènements" />
            </HBox>
            <Label text="Description de l'évènement" wrapText="true" />
            <GridPane hgap="16.0" vgap="12.0">
                <Label text="Horaires" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Label text="Prix d'entrée" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <Label text="Capacité" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Label text="Galerie" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            </GridPane>
        </VBox>
    </center>
</BorderPane>

