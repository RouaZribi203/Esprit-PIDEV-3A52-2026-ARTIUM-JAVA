<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox fx:id="playerBar" alignment="CENTER_LEFT" prefHeight="72.0" spacing="12.0" styleClass="mini-audio-player" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.amateur.MiniAudioPlayerController">
    <padding>
        <Insets bottom="10.0" left="16.0" right="16.0" top="10.0" />
    </padding>

    <Button mnemonicParsing="false" onAction="#onPrevTrack" styleClass="mini-audio-button" text="⏮" />
    <Button fx:id="togglePlayButton" mnemonicParsing="false" onAction="#onTogglePlay" styleClass="mini-audio-button" text="▶" />
    <Button mnemonicParsing="false" onAction="#onNextTrack" styleClass="mini-audio-button" text="⏭" />

    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
        <Label styleClass="mini-audio-title" text="Aucune piste en cours" />
        <Label styleClass="mini-audio-artist" text="Le lecteur apparaîtra ici quand une musique sera lancée." />
    </VBox>

    <Region prefWidth="12.0" />

    <Slider maxWidth="300.0" prefWidth="300.0" styleClass="mini-seek-slider" />

    <Region prefWidth="12.0" />

    <Button mnemonicParsing="false" onAction="#onOpenMusic" styleClass="mini-audio-open" text="↗ Ouvrir Musique" />
</HBox>

