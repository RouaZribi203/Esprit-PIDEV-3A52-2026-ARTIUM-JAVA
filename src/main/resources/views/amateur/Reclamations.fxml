<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" styleClass="page-root" stylesheets="@/views/styles/amateur-reclamations.css" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.amateur.ReclamationsController">

    <padding>
        <Insets bottom="18.0" left="18.0" right="18.0" top="16.0" />
    </padding>

    <Label styleClass="page-title" text="Réclamations" />

    <VBox spacing="14.0" styleClass="amateur-page-card reclamations-card" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
        </padding>

        <TabPane fx:id="tabs" styleClass="reclamations-tabs" tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Envoyer Réclamation">
                    <content>
                        <VBox spacing="12.0">
                            <Label styleClass="form-title" text="Soumettre une Réclamation" />

                            <VBox spacing="6.0">
                                <Label styleClass="form-label" text="Type" />
                                <ComboBox fx:id="typeCombo" maxWidth="1.7976931348623157E308" promptText="Sélectionner une catégorie" styleClass="input-control" />
                            </VBox>

                            <VBox spacing="6.0" VBox.vgrow="ALWAYS">
                                <Label styleClass="form-label" text="Description" />
                                <TextArea fx:id="descriptionArea" maxWidth="1.7976931348623157E308" prefRowCount="8" promptText="Décrivez votre problème en détail..." styleClass="input-control" wrapText="true" VBox.vgrow="ALWAYS" />
                            </VBox>

                            <VBox spacing="6.0">
                                <Label styleClass="form-label" text="Piece jointe (image ou PDF)" />
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <Button onAction="#onChooseAttachment" styleClass="btn-secondary" text="Choisir un fichier" />
                                    <Button onAction="#onClearAttachment" styleClass="btn-secondary" text="Retirer" />
                                    <Label fx:id="selectedAttachmentLabel" maxWidth="1.7976931348623157E308" text="Aucun fichier selectionne" HBox.hgrow="ALWAYS" />
                                </HBox>
                            </VBox>

                            <Label fx:id="sendValidationLabel" managed="false" visible="false" wrapText="true" styleClass="form-validation-error" style="-fx-text-fill: #dc2626; -fx-font-size: 12px;" />

                            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                <Button fx:id="resetButton" onAction="#onReset" styleClass="btn-secondary" text="Réinitialiser" />
                                <Button fx:id="sendButton" onAction="#onSend" styleClass="btn-primary" text="Envoyer la réclamation" />
                            </HBox>
                        </VBox>
                    </content>
                </Tab>

                <Tab text="Mes Réclamations">
                    <content>
                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <Label styleClass="form-title" text="Mes Réclamations" />

                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <Button fx:id="typeFilterAll" text="Tous les types" onAction="#onTypeFilterAll" styleClass="type-filter-btn,type-filter-active" />
                                <Button fx:id="typeFilterPayment" text="Paiement" onAction="#onTypeFilterPayment" styleClass="type-filter-btn" />
                                <Button fx:id="typeFilterWork" text="Oeuvre" onAction="#onTypeFilterWork" styleClass="type-filter-btn" />
                                <Button fx:id="typeFilterEvent" text="Evenement" onAction="#onTypeFilterEvent" styleClass="type-filter-btn" />
                                <Button fx:id="typeFilterAccount" text="Compte" onAction="#onTypeFilterAccount" styleClass="type-filter-btn" />
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <TextField fx:id="mySearchField" promptText="Rechercher une reclamation..." styleClass="input-control" HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="myStatutFilter" prefWidth="230" promptText="Filtrer par statut" styleClass="input-control" />
                            </HBox>



                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="amateur-scroll" VBox.vgrow="ALWAYS">
                                <content>
                                    <VBox fx:id="myReclamationsContainer" spacing="10.0" />
                                </content>
                            </ScrollPane>

                            <Label fx:id="emptyMyReclamationsLabel" managed="false" styleClass="empty-hint" text="Aucune réclamation à afficher." visible="false" />
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </VBox>
</VBox>
