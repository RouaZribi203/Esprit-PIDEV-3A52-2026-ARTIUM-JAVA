<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.amateur.ReclamationsController">
    <top>
        <VBox spacing="8.0" styleClass="amateur-page-card">
            <padding>
                <Insets bottom="20.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <Label styleClass="page-title" text="Réclamations" />
            <Label styleClass="page-subtitle" text="Formulaire et liste structurés pour le module amateur." wrapText="true" />
        </VBox>
    </top>
    <center>
        <VBox spacing="14.0" styleClass="amateur-page-card">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="0.0" />
            </padding>
            <TabPane prefHeight="520.0">
                <tabs>
                    <Tab closable="false" text="Envoyer Réclamation">
                        <content>
                            <VBox spacing="10.0">
                                <ComboBox promptText="Type" />
                                <TextArea prefRowCount="5" promptText="Décrivez votre problème en détail..." />
                                <Button mnemonicParsing="false" text="Envoyer la réclamation" />
                            </VBox>
                        </content>
                    </Tab>
                    <Tab closable="false" text="Mes Réclamations">
                        <content>
                            <VBox spacing="10.0">
                                <HBox spacing="8.0">
                                    <TextField HBox.hgrow="ALWAYS" promptText="Rechercher..." />
                                    <ComboBox prefWidth="140.0" promptText="Statut" />
                                    <ComboBox prefWidth="140.0" promptText="Type" />
                                    <DatePicker prefWidth="140.0" />
                                </HBox>
                                <StackPane minHeight="280.0" styleClass="empty-state-card">
                                    <Label text="Liste structurée des réclamations" />
                                </StackPane>
                            </VBox>
                        </content>
                    </Tab>
                </tabs>
            </TabPane>
        </VBox>
    </center>
</BorderPane>

