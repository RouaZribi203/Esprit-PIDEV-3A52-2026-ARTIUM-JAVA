<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f3f4f6;" stylesheets="@/views/styles/amateur-reclamations.css" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.amateur.ReclamationsController">
    <top>
        <VBox spacing="20.0" style="-fx-background-color: #ffffff; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2); -fx-padding: 30px 40px 20px 40px;">
            <HBox alignment="CENTER_LEFT" spacing="16.0">
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label text="Réclamations" style="-fx-font-size: 32px; -fx-font-weight: 900; -fx-text-fill: #111827;" />
                    <Label text="Signalez un problème ou suivez l'état de vos réclamations." style="-fx-font-size: 15px; -fx-text-fill: #6b7280;" />
                </VBox>
            </HBox>

            <HBox spacing="12.0" style="-fx-padding: 10px 0 0 0;">
                <Button fx:id="btnSend" mnemonicParsing="false" onAction="#handleShowSend" text="Envoyer Réclamation" style="-fx-background-color: transparent; -fx-text-fill: #111827; -fx-font-weight: bold; -fx-font-size: 15px; -fx-border-color: transparent transparent #111827 transparent; -fx-border-width: 0 0 2px 0; -fx-padding: 8px 12px; -fx-cursor: hand;" />
                <Button fx:id="btnMyReclamations" mnemonicParsing="false" onAction="#handleShowMyReclamations" text="Mes Réclamations" style="-fx-background-color: transparent; -fx-text-fill: #6b7280; -fx-font-weight: bold; -fx-font-size: 15px; -fx-border-color: transparent; -fx-padding: 8px 12px; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16.0" style="-fx-padding: 30px 40px 40px 40px;">
            <VBox fx:id="sendSection" spacing="16.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px; -fx-border-color: #e5e7eb; -fx-border-radius: 12px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                <Label styleClass="form-title" text="Soumettre une Réclamation" style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #111827;" />

                <VBox spacing="6.0">
                    <Label styleClass="form-label" text="Type" style="-fx-font-weight: bold; -fx-text-fill: #374151;" />
                    <ComboBox fx:id="typeCombo" maxWidth="1.7976931348623157E308" promptText="Sélectionner une catégorie" styleClass="input-control" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 8px; -fx-background-radius: 8px;" />
                </VBox>

                <VBox spacing="6.0" VBox.vgrow="ALWAYS">
                    <Label styleClass="form-label" text="Description" style="-fx-font-weight: bold; -fx-text-fill: #374151;" />
                    <TextArea fx:id="descriptionArea" maxWidth="1.7976931348623157E308" prefRowCount="8" promptText="Décrivez votre problème en détail..." styleClass="input-control" wrapText="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 8px; -fx-background-radius: 8px;" />
                </VBox>

                <VBox spacing="6.0">
                    <Label styleClass="form-label" text="Pièce jointe (image ou PDF)" style="-fx-font-weight: bold; -fx-text-fill: #374151;" />
                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Button onAction="#onChooseAttachment" styleClass="btn-secondary" text="Choisir un fichier" style="-fx-background-color: #e5e7eb; -fx-text-fill: #111827; -fx-font-weight: bold; -fx-padding: 8px 16px; -fx-background-radius: 8px; -fx-cursor: hand;" />
                        <Button onAction="#onClearAttachment" styleClass="btn-secondary" text="Retirer" style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-padding: 8px 16px; -fx-background-radius: 8px; -fx-cursor: hand;" />
                        <Label fx:id="selectedAttachmentLabel" maxWidth="1.7976931348623157E308" text="Aucun fichier sélectionné" HBox.hgrow="ALWAYS" style="-fx-text-fill: #6b7280;" />
                    </HBox>
                </VBox>

                <Label fx:id="sendValidationLabel" managed="false" visible="false" wrapText="true" styleClass="form-validation-error" style="-fx-text-fill: #dc2626; -fx-font-size: 13px; -fx-font-weight: bold;" />

                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <Button fx:id="resetButton" onAction="#onReset" styleClass="btn-secondary" text="Réinitialiser" style="-fx-background-color: #f3f4f6; -fx-text-fill: #4b5563; -fx-font-weight: bold; -fx-padding: 10px 20px; -fx-background-radius: 8px; -fx-cursor: hand;" />
                    <Button fx:id="sendButton" onAction="#onSend" styleClass="btn-primary" text="Envoyer la réclamation" style="-fx-background-color: #1f2937; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px 24px; -fx-background-radius: 8px; -fx-cursor: hand;" />
                </HBox>
            </VBox>

            <VBox fx:id="myReclamationsSection" spacing="16.0" visible="false" managed="false" VBox.vgrow="ALWAYS" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px; -fx-border-color: #e5e7eb; -fx-border-radius: 12px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                <Label styleClass="form-title" text="Mes Réclamations" style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #111827;" />

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Button fx:id="typeFilterAll" text="Tous les types" onAction="#onTypeFilterAll" styleClass="type-filter-btn,type-filter-active" />
                    <Button fx:id="typeFilterPayment" text="Paiement" onAction="#onTypeFilterPayment" styleClass="type-filter-btn" />
                    <Button fx:id="typeFilterWork" text="Oeuvre" onAction="#onTypeFilterWork" styleClass="type-filter-btn" />
                    <Button fx:id="typeFilterEvent" text="Evènement" onAction="#onTypeFilterEvent" styleClass="type-filter-btn" />
                    <Button fx:id="typeFilterAccount" text="Compte" onAction="#onTypeFilterAccount" styleClass="type-filter-btn" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <TextField fx:id="mySearchField" promptText="Rechercher une réclamation..." styleClass="input-control" HBox.hgrow="ALWAYS" style="-fx-background-color: #f9fafb; -fx-border-color: #e5e7eb; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 10px 16px;" />
                    <ComboBox fx:id="myStatutFilter" prefWidth="230.0" promptText="Filtrer par statut" styleClass="input-control" style="-fx-background-color: #f9fafb; -fx-border-color: #e5e7eb; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 5px 10px;" />
                </HBox>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="myReclamationsContainer" spacing="12.0" />
                    </content>
                </ScrollPane>

                <Label fx:id="emptyMyReclamationsLabel" managed="false" styleClass="empty-hint" text="Aucune réclamation à afficher." visible="false" style="-fx-text-fill: #6b7280; -fx-font-style: italic;" />
            </VBox>
        </VBox>
    </center>
</BorderPane>
