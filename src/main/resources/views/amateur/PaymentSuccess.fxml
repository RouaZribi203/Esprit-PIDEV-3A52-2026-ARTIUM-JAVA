<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>

<VBox alignment="CENTER" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.amateur.PaymentController">
    <VBox maxWidth="600.0" spacing="24.0" alignment="CENTER" style="-fx-background-color: #ffffff; -fx-background-radius: 16px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 25, 0, 0, 10);">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>

        <StackPane>
            <Circle radius="40.0" fill="#34d399" />
            <Label text="✓" style="-fx-font-size: 40px; -fx-text-fill: white; -fx-font-weight: bold;" />
        </StackPane>

        <VBox alignment="CENTER" spacing="8.0">
            <Label text="Paiement réussi !" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
            <Label text="Votre ticket pour cet évènement a été acheté avec succès." wrapText="true" textAlignment="CENTER" style="-fx-font-size: 15px; -fx-text-fill: #6b7280;" />
        </VBox>

        <VBox spacing="16.0" style="-fx-background-color: #f9fafb; -fx-background-radius: 12px; -fx-padding: 20px; -fx-border-color: #e5e7eb; -fx-border-radius: 12px; -fx-border-width: 1px;">
            <Label text="Détails du Ticket" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #374151;" />
            
            <GridPane hgap="16.0" vgap="12.0">
                <columnConstraints>
                    <ColumnConstraints minWidth="120.0" prefWidth="120.0" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>
                
                <Label text="Référence" style="-fx-text-fill: #6b7280; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <Label fx:id="ticketReferenceLabel" style="-fx-text-fill: #111827; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                
                <Label text="Evènement" style="-fx-text-fill: #6b7280; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <Label fx:id="eventIdLabel" style="-fx-text-fill: #111827; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                
                <Label text="Date d'achat" style="-fx-text-fill: #6b7280; -fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <Label fx:id="purchaseDateLabel" style="-fx-text-fill: #111827;" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                
                <Label text="Acheteur" style="-fx-text-fill: #6b7280; -fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <Label fx:id="userIdLabel" style="-fx-text-fill: #111827;" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                
                <Label text="Prix Payé" style="-fx-text-fill: #6b7280; -fx-font-weight: bold;" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                <Label fx:id="qrPayloadLabel" style="-fx-text-fill: #059669; -fx-font-weight: bold;" GridPane.rowIndex="4" GridPane.columnIndex="1" />
            </GridPane>
        </VBox>

        <VBox spacing="12.0" alignment="CENTER" prefWidth="1000.0">
            <HBox spacing="12.0" alignment="CENTER">
                <Button mnemonicParsing="false" onAction="#onShowQrCodeClick" text="Voir QR Code" style="-fx-background-color: #f3f4f6; -fx-text-fill: #374151; -fx-font-weight: bold; -fx-padding: 10px 20px; -fx-background-radius: 8px; -fx-cursor: hand;" />
                <Button mnemonicParsing="false" onAction="#onShowTicketClick" text="Aperçu du Ticket" style="-fx-background-color: #f3f4f6; -fx-text-fill: #374151; -fx-font-weight: bold; -fx-padding: 10px 20px; -fx-background-radius: 8px; -fx-cursor: hand;" />
            </HBox>
            <Button mnemonicParsing="false" onAction="#onDownloadTicketPdfClick" text="Télécharger le PDF" maxWidth="Infinity" style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12px 20px; -fx-background-radius: 8px; -fx-cursor: hand; -fx-font-size: 15px;" />
        </VBox>

        <HBox spacing="16.0" alignment="CENTER">
            <Button mnemonicParsing="false" onAction="#onBackToEventClick" text="Retour à l'évènement" style="-fx-background-color: transparent; -fx-text-fill: #6b7280; -fx-cursor: hand; -fx-underline: true;" />
            <Button mnemonicParsing="false" onAction="#onBackToEventsClick" text="Tous les évènements" style="-fx-background-color: transparent; -fx-text-fill: #6b7280; -fx-cursor: hand; -fx-underline: true;" />
        </HBox>
    </VBox>
</VBox>
