<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="14.0" styleClass="amateur-page-card" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
    </padding>
    <StackPane minHeight="100.0" prefHeight="100.0" prefWidth="100.0" styleClass="success-icon-circle">
        <Label styleClass="success-icon" text="✓" />
    </StackPane>
    <Label styleClass="page-title" text="Paiement réussi !" />
    <Label styleClass="page-subtitle" text="Votre ticket pour cet évènement a été acheté avec succès." wrapText="true" />
    <Button mnemonicParsing="false" text="Afficher le QR Code" />
    <Button mnemonicParsing="false" text="Télécharger le ticket PDF" />
    <Button mnemonicParsing="false" text="Retour à l'évènement" />
    <Button mnemonicParsing="false" text="Tous les évènements" />
    <Label styleClass="page-caption" text="Transaction reference : session_id" />
</VBox>

