<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox maxWidth="Infinity" spacing="0.0" style="-fx-background-color: #ffffff; -fx-background-radius: 16px; -fx-border-color: #e5e7eb; -fx-border-radius: 16px; -fx-border-width: 1px; -fx-cursor: hand;" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.amateur.EventCardController" onMouseClicked="#onCardClick" GridPane.hgrow="ALWAYS">
    
    <!-- Image Header with Category Badge -->
    <StackPane minHeight="180.0">
        <Region fx:id="coverImageRegion" minHeight="180.0" maxWidth="Infinity" style="-fx-background-color: #f3f4f6; -fx-background-radius: 16 16 0 0;" />
        <VBox alignment="TOP_LEFT">
            <padding>
                <Insets top="16.0" left="16.0" />
            </padding>
            <Label fx:id="categoryBadgeLabel" text="Exposition" />
        </VBox>
    </StackPane>

    <!-- Content Body -->
    <VBox spacing="10.0" style="-fx-padding: 12px 16px 16px 16px;">
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <Label fx:id="titleLabel" text="Titre" wrapText="true" style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #111827;" HBox.hgrow="ALWAYS" />
        </HBox>

        <VBox spacing="4.0">
            <HBox spacing="6.0" alignment="CENTER_LEFT">
                <Label text="📅" style="-fx-font-size: 13px;" />
                <Label fx:id="dateLabel" text="Date" wrapText="true" style="-fx-text-fill: #6b7280; -fx-font-size: 13px; -fx-font-weight: bold;" />
            </HBox>
            <HBox spacing="6.0" alignment="CENTER_LEFT">
                <Label text="👥" style="-fx-font-size: 13px;" />
                <Label fx:id="placeLabel" text="100 places" wrapText="true" style="-fx-text-fill: #6b7280; -fx-font-size: 13px;" />
            </HBox>
        </VBox>

        <HBox alignment="CENTER_LEFT" style="-fx-padding: 8px 0 0 0; -fx-border-color: #f3f4f6; -fx-border-width: 1px 0 0 0;">
            <Label fx:id="statusLabel" text="A venir" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="priceLabel" text="20 TND" style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #15803d;" />
        </HBox>

        <Label fx:id="scoreLabel" text="Match IA: -" style="-fx-text-fill: #8b5cf6; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-color: #ede9fe; -fx-padding: 4px 10px; -fx-background-radius: 8px;" />

        <Label fx:id="descriptionLabel" text="Description" wrapText="true" style="-fx-text-fill: #9ca3af; -fx-font-size: 13px; -fx-max-height: 40px; -fx-wrap-text: true;" />
    </VBox>
</VBox>
