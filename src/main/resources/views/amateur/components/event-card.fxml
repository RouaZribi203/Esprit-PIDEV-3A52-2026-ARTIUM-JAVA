<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="260.0" spacing="10.0" styleClass="amateur-event-card" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.amateur.EventCardController" onMouseClicked="#onCardClick">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <StackPane prefHeight="185.0" styleClass="amateur-event-cover">
        <ImageView fx:id="coverImageView" fitHeight="185.0" fitWidth="240.0" pickOnBounds="true" preserveRatio="true" />
        <Label fx:id="categoryBadgeLabel" styleClass="amateur-event-badge" text="Exposition" StackPane.alignment="TOP_LEFT" />
    </StackPane>

    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <Label fx:id="titleLabel" styleClass="amateur-event-title" text="Titre" wrapText="true" />
        <Region HBox.hgrow="ALWAYS" />
        <StackPane styleClass="amateur-details-chip">
            <Label text="⌗" />
        </StackPane>
    </HBox>

    <VBox spacing="6.0">
        <Label fx:id="dateLabel" styleClass="amateur-event-meta" text="Date" wrapText="true" />
        <Label fx:id="placeLabel" styleClass="amateur-event-meta" text="100 places" wrapText="true" />
    </VBox>

    <HBox alignment="CENTER_LEFT">
        <Label fx:id="statusLabel" styleClass="amateur-event-status" text="A venir" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="priceLabel" styleClass="amateur-event-price" text="20 TND" />
    </HBox>

    <Label fx:id="descriptionLabel" styleClass="amateur-event-description" text="Description" wrapText="true" />
</VBox>

