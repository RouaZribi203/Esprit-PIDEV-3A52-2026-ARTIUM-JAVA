<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.amateur.MusicfrontController">
    <top>
        <VBox spacing="10.0" styleClass="amateur-page-card music-card">
            <padding>
                <Insets bottom="20.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <Label styleClass="page-title" text="Découvrir Musique" />
            <Label styleClass="page-subtitle" text="Cliquez sur une carte pour écouter la musique" />
            <HBox spacing="10.0">
                <TextField fx:id="searchField" HBox.hgrow="ALWAYS" onAction="#handleSearch" promptText="Titre, description, genre" />
                <Button mnemonicParsing="false" onAction="#handleSearch" text="Rechercher" />
                <Button mnemonicParsing="false" onAction="#handleClearSearch" text="Effacer" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="14.0" styleClass="amateur-page-card music-card">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="0.0" />
            </padding>

            <Label text="Musiques disponibles" />
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="430.0" styleClass="amateur-scroll">
                <content>
                    <VBox spacing="12.0">
                        <TilePane fx:id="musicGrid" hgap="12.0" prefColumns="4" vgap="12.0" />
                        <Label fx:id="emptyListLabel" styleClass="page-caption" text="Aucune musique disponible pour le moment." wrapText="true" />
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>

    <bottom>
        <VBox spacing="8.0" styleClass="amateur-page-card music-card">
            <padding>
                <Insets bottom="16.0" left="24.0" right="24.0" top="16.0" />
            </padding>
            <Label text="Lecture en cours" />
            <Label fx:id="nowPlayingTitleLabel" styleClass="mini-audio-title" text="Selectionnez une musique" wrapText="true" />
            <Label fx:id="nowPlayingMetaLabel" styleClass="mini-audio-artist" text="Genre: -" />
            <HBox spacing="10.0">
                <Button mnemonicParsing="false" onAction="#handlePreviousTrack" text="Prev" />
                <Button fx:id="playPauseButton" mnemonicParsing="false" onAction="#handlePlayPause" text="Play" />
                <Button mnemonicParsing="false" onAction="#handleNextTrack" text="Next" />
                <Label fx:id="playerStatusLabel" styleClass="page-caption" text="Pret" />
            </HBox>
        </VBox>
    </bottom>
</BorderPane>

