<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.amateur.MusicfrontController">
    <top>
        <VBox spacing="12.0" styleClass="amateur-page-card music-card">
            <padding>
                <Insets bottom="20.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <Label styleClass="page-title" text="Découvrir Musique" />
            <Label styleClass="page-subtitle" text="Cliquez sur une carte pour écouter la musique" />
            <HBox fx:id="musicSearchBar" spacing="10.0">
                <TextField fx:id="searchField" HBox.hgrow="ALWAYS" onAction="#handleSearch" promptText="Titre, description, genre" />
                <Button mnemonicParsing="false" onAction="#handleSearch" text="Rechercher" />
                <Button mnemonicParsing="false" onAction="#handleClearSearch" text="Effacer" />
                <ComboBox fx:id="sortMusicComboBox" prefWidth="170.0" promptText="Tri" />
            </HBox>

            <HBox fx:id="playlistSearchBar" spacing="10.0" visible="false" managed="false">
                <TextField fx:id="playlistSearchField" HBox.hgrow="ALWAYS" onAction="#handleSearchPlaylist" promptText="Nom, description" />
                <Button mnemonicParsing="false" onAction="#handleSearchPlaylist" text="Rechercher" />
                <Button mnemonicParsing="false" onAction="#handleClearPlaylistSearch" text="Effacer" />
                <ComboBox fx:id="sortPlaylistComboBox" prefWidth="170.0" promptText="Tri" />
            </HBox>

            <HBox spacing="10.0">
                <Button fx:id="musiqueSectionButton" mnemonicParsing="false" onAction="#handleShowMusiqueSection" text="Musiques" />
                <Button fx:id="playlistsSectionButton" mnemonicParsing="false" onAction="#handleShowPlaylistsSection" text="Playlists" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="14.0" styleClass="amateur-page-card music-card">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="0.0" />
            </padding>

            <VBox fx:id="musiqueSection" spacing="8.0">
                <Label text="Musiques disponibles" />
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="430.0" styleClass="amateur-scroll">
                    <VBox spacing="12.0">
                        <TilePane fx:id="musicGrid" hgap="12.0" prefColumns="4" vgap="12.0" />
                        <Label fx:id="emptyListLabel" styleClass="page-caption" text="Aucune musique disponible pour le moment." wrapText="true" />
                    </VBox>
                </ScrollPane>


            </VBox>

            <VBox fx:id="playlistsSection" spacing="16.0" visible="false" managed="false">
                <Label style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: white;" text="Mes Playlists" />

                <VBox fx:id="aiPlaylistSection" spacing="12.0" style="-fx-background-color: linear-gradient(to right, rgba(139,92,246,0.1), rgba(61,59,194,0.1)); -fx-background-radius: 12; -fx-padding: 18; -fx-border-color: rgba(139,92,246,0.25); -fx-border-radius: 12; -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.1), 10, 0, 0, 4);">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: 800;" text="🤖 Générer avec l'IA" />
                        <Region HBox.hgrow="ALWAYS" />
                    </HBox>
                    <Label style="-fx-text-fill: #b3b9c5; -fx-font-size: 13px;" text="Décrivez l'ambiance, le genre ou l'activité, et l'IA créera une playlist sur mesure." wrapText="true" />
                    <HBox spacing="12.0">
                        <TextField fx:id="aiPlaylistPromptField" HBox.hgrow="ALWAYS" style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-padding: 10 14; -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8;" promptText="Ex: Musique énergique pour l'entraînement, chansons douces pour étudier..." />
                        <Button fx:id="generatePlaylistButton" mnemonicParsing="false" onAction="#handleGeneratePlaylistWithAI" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;" text="Générer" />
                    </HBox>
                    <Label fx:id="aiPlaylistStatusLabel" style="-fx-text-fill: #a78bfa; -fx-font-size: 12px; -fx-font-style: italic;" text="Prêt à générer votre playlist" wrapText="true" />
                </VBox>

                <HBox spacing="10.0">
                    <Button fx:id="togglePlaylistFormButton" mnemonicParsing="false" onAction="#handleTogglePlaylistForm" style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;" text="+ Nouvelle playlist" />
                </HBox>

                <VBox fx:id="playlistDetailSection" spacing="12.0" visible="false" managed="false" style="-fx-background-color: rgba(255,255,255,0.03); -fx-background-radius: 12; -fx-padding: 16; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 12;">
                    <HBox spacing="12.0" alignment="CENTER_LEFT">
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                            <Label fx:id="playlistDetailTitleLabel" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Aucune playlist sélectionnée" />
                            <Label fx:id="playlistDetailMetaLabel" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;" text="Cliquez sur une playlist pour voir ses musiques." wrapText="true" />
                        </VBox>
                        <Button mnemonicParsing="false" onAction="#handleEditSelectedPlaylist" style="-fx-background-color: rgba(59, 130, 246, 0.2); -fx-text-fill: #60a5fa; -fx-background-radius: 6; -fx-padding: 6 12; -fx-cursor: hand;" text="Modifier" />
                        <Button mnemonicParsing="false" onAction="#handleDeleteSelectedPlaylist" style="-fx-background-color: rgba(239, 68, 68, 0.2); -fx-text-fill: #f87171; -fx-background-radius: 6; -fx-padding: 6 12; -fx-cursor: hand;" text="Supprimer" />
                        <Button fx:id="closePlaylistDetailButton" mnemonicParsing="false" onAction="#handleClosePlaylistDetail" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 12; -fx-cursor: hand;" text="✕" />
                    </HBox>

                    <Label fx:id="playlistSongsEmptyLabel" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" text="Aucune musique dans cette playlist." wrapText="true" />
                    <TilePane fx:id="playlistSongsBox" hgap="12.0" prefColumns="4" vgap="12.0" />
                </VBox>

                <VBox fx:id="playlistFormSection" spacing="16.0" style="-fx-background-color: linear-gradient(to bottom right, rgba(30, 41, 59, 0.8), rgba(15, 23, 42, 0.9)); -fx-background-radius: 16; -fx-padding: 24; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 15, 0, 0, 5);" visible="false" managed="false">
                    <VBox spacing="4.0">
                        <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 800;" text="✨ Créer une nouvelle playlist" />
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" text="Personnalisez votre collection en lui donnant un nom, une description et une belle couverture." wrapText="true" />
                    </VBox>
                    <VBox spacing="6.0">
                        <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 13px; -fx-font-weight: bold;" text="Nom de la playlist" />
                        <TextField fx:id="playlistNameField" style="-fx-background-color: rgba(0,0,0,0.2); -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-padding: 12 16; -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-font-size: 14px;" promptText="Ex: Ma playlist d'été" />
                    </VBox>
                    <VBox spacing="6.0">
                        <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 13px; -fx-font-weight: bold;" text="Description (facultative)" />
                        <TextArea fx:id="playlistDescriptionArea" prefRowCount="3" style="-fx-background-color: rgba(0,0,0,0.2); -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-padding: 12 16; -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-font-size: 14px;" promptText="Décrivez l'ambiance ou le thème de cette playlist..." wrapText="true" />
                    </VBox>
                    <VBox spacing="6.0">
                        <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 13px; -fx-font-weight: bold;" text="Image de couverture (facultative)" />
                        <HBox spacing="12.0">
                            <TextField fx:id="playlistImageField" editable="false" HBox.hgrow="ALWAYS" style="-fx-background-color: rgba(0,0,0,0.2); -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-padding: 12 16; -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-font-size: 14px;" promptText="Choisissez une image attrayante..." />
                            <Button mnemonicParsing="false" onAction="#handleChoosePlaylistImage" style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 20; -fx-background-radius: 8; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 8;" text="Parcourir" />
                        </HBox>
                    </VBox>
                    <HBox alignment="CENTER_RIGHT" spacing="12.0">
                        <Button fx:id="createPlaylistButton" mnemonicParsing="false" onAction="#handleCreatePlaylist" style="-fx-background-color: linear-gradient(to right, #3b82f6, #2563eb); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-padding: 12 28; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(59, 130, 246, 0.4), 10, 0, 0, 2);" text="Créer la playlist" />
                    </HBox>
                </VBox>

                <Label fx:id="playlistFeedbackLabel" style="-fx-text-fill: #10b981; -fx-font-size: 13px;" wrapText="true" />
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="430.0" styleClass="amateur-scroll, amateur-events-scroll">
                    <content>
                        <TilePane fx:id="playlistGrid" hgap="16.0" prefColumns="3" vgap="16.0" />
                    </content>
                </ScrollPane>
            </VBox>
        </VBox>
    </center>

</BorderPane>

