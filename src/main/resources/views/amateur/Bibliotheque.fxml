<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<BorderPane xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.amateur.BibliofrontController">
    <top>
        <VBox spacing="10.0" styleClass="amateur-page-card">
            <padding>
                <Insets bottom="20.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <Label styleClass="page-title" text="Bibliothèque numérique" />
            <HBox spacing="10.0">
                <TextField fx:id="searchField" HBox.hgrow="ALWAYS" promptText="Titre ou catégorie" />
                <Button mnemonicParsing="false" onAction="#onSearch" text="Recherche" />
                <Button mnemonicParsing="false" onAction="#onRefresh" text="Rafraîchir" />
                <ToggleButton fx:id="filterRentedToggle" mnemonicParsing="false" text="Mes locations" />
            </HBox>
            <HBox spacing="8.0">
                <Label styleClass="badge-pill" text="Livres numériques" />
                <Label styleClass="badge-pill" text="Accès immédiat" />
                <Label styleClass="badge-pill" text="Louer &amp; Lire" />
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="14.0" styleClass="amateur-page-card">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="16.0" />
            </padding>
            <Label styleClass="page-subtitle" text="Liste des livres disponibles." />
            <ScrollPane fx:id="cardsScroll" VBox.vgrow="ALWAYS" fitToWidth="true" style="-fx-background-color: transparent;">
                <content>
                    <TilePane fx:id="cardsTile" prefTileWidth="220.0" hgap="16.0" vgap="16.0" />
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
