<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.shape.SVGPath?>

<HBox alignment="CENTER_LEFT" prefHeight="66.0" spacing="12.0" styleClass="amateur-navbar" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.amateur.NavbarAmateurController">
    <padding>
        <Insets bottom="10.0" left="16.0" right="40.0" top="10.0" />
    </padding>

    <Button fx:id="anchorButton" mnemonicParsing="false" prefHeight="38.0" prefWidth="38.0" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-border-color: transparent;">
        <graphic>
            <SVGPath content="M4 6h16M4 12h16M4 18h16" fill="TRANSPARENT" stroke="#475569" strokeLineCap="ROUND" strokeWidth="2" />
        </graphic>
    </Button>
    
    <!-- ARTIUM Logo -->
    <HBox alignment="CENTER" spacing="8.0" style="-fx-padding: 0 16 0 8;">
        <ImageView fitHeight="38.0" preserveRatio="true">
            <image>
                <Image url="@../images/logo2.png" />
            </image>
        </ImageView>
    </HBox>

    <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="280.0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #e2e8f0; -fx-padding: 0 16 0 16;">
        <SVGPath content="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" fill="TRANSPARENT" stroke="#94a3b8" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2" />
        <TextField promptText="Recherche..." style="-fx-background-color: transparent; -fx-prompt-text-fill: #94a3b8; -fx-text-fill: #1e293b; -fx-padding: 0 0 0 8;" HBox.hgrow="ALWAYS" />
    </HBox>

    <Region HBox.hgrow="ALWAYS" />

    <MenuButton fx:id="oeuvresButton" mnemonicParsing="false" prefHeight="38.0" styleClass="nav-menu-button" text="Oeuvres">
        <items>
            <MenuItem mnemonicParsing="false" onAction="#onFeedClick" styleClass="nav-dropdown-item" text="Toutes les oeuvres" />
            <MenuItem mnemonicParsing="false" onAction="#onFeedPeinturesClick" styleClass="nav-dropdown-item" text="Peintures" />
            <MenuItem mnemonicParsing="false" onAction="#onFeedSculpturesClick" styleClass="nav-dropdown-item" text="Sculptures" />
            <MenuItem mnemonicParsing="false" onAction="#onFeedPhotosClick" styleClass="nav-dropdown-item" text="Photographies" />
            <MenuItem mnemonicParsing="false" onAction="#onFeedRecommendationsClick" styleClass="nav-dropdown-item" text="Recommandations" />
        </items>
    </MenuButton>

    <Button fx:id="bibliothequeButton" mnemonicParsing="false" prefHeight="38.0" styleClass="nav-button-link" text="Bibliothèque" />
    <Button fx:id="musiqueButton" mnemonicParsing="false" prefHeight="38.0" styleClass="nav-button-link" text="Musique" />

    <Region HBox.hgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="12.0">
        <MenuButton fx:id="notificationsButton" mnemonicParsing="false" onAction="#onNotificationsClick" prefHeight="38.0" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-background-radius: 50; -fx-border-radius: 50; -fx-padding: 4 12 4 12; -fx-cursor: hand; -fx-font-weight: 600; -fx-text-fill: #1e293b;">
        <graphic>
            <SVGPath content="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" fill="TRANSPARENT" stroke="#64748b" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
        </graphic>
        <items>
            <MenuItem mnemonicParsing="false" styleClass="notifications-header" text="Notifications" />
            <SeparatorMenuItem />
            <MenuItem mnemonicParsing="false" text="Aucune notification pour le moment." />
        </items>
    </MenuButton>
    </HBox>
</HBox>
