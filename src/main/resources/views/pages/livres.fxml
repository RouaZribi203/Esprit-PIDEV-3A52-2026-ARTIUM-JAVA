<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox spacing="16.0" styleClass="page-root" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LivresController">
    <padding><Insets bottom="24.0" left="28.0" right="24.0" top="28.0" /></padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <VBox spacing="4.0">
            <Label styleClass="page-title" text="Gestion des Livres" />
            <Label styleClass="page-subtitle" text="Administrez le catalogue de la bibliothèque" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <TextField fx:id="searchField" prefWidth="280.0" promptText="Rechercher par titre, catégorie ou auteur..." styleClass="search-field" />
            <Button mnemonicParsing="false" onAction="#onSearch" text="🔍" styleClass="icon-btn" />
            <Button fx:id="addBookButton" mnemonicParsing="false" onAction="#onShowForm" styleClass="primary-button" text="+ Ajouter un livre" />
        </HBox>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="cards-scroll">
        <TilePane fx:id="cardsTile" hgap="24.0" vgap="24.0" prefColumns="0" alignment="TOP_LEFT" />
    </ScrollPane>

    <!-- Hidden template for the popup form (not visible in main view) -->
    <fx:define>
        <VBox fx:id="formPanel" spacing="20.0" styleClass="popup-form-container" prefWidth="500.0">
            <padding><Insets top="24.0" right="30.0" bottom="24.0" left="30.0" /></padding>
            
            <VBox spacing="8.0">
                <Label fx:id="formTitleLabel" text="Ajouter un nouveau livre" styleClass="form-title" />
                <Label text="Remplissez les informations ci-dessous" styleClass="form-subtitle" />
            </VBox>

            <GridPane hgap="15.0" vgap="15.0">
                <columnConstraints>
                    <ColumnConstraints minWidth="120.0" prefWidth="120.0" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>

                <Label text="Couverture" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="field-label" />
                <HBox spacing="15.0" GridPane.rowIndex="0" GridPane.columnIndex="1" alignment="CENTER_LEFT">
                    <StackPane styleClass="image-preview-container">
                        <Rectangle width="80.0" height="55.0" styleClass="image-placeholder" />
                        <ImageView fx:id="couvertureImageView" fitWidth="80.0" fitHeight="55.0" preserveRatio="true" />
                    </StackPane>
                    <VBox spacing="5.0">
                        <Button mnemonicParsing="false" onAction="#onChooseImage" text="Parcourir" styleClass="secondary-button" />
                        <Label fx:id="couvertureLabel" text="Aucun fichier" styleClass="file-name-label" />
                    </VBox>
                </HBox>

                <Label text="Titre *" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="field-label" />
                <TextField fx:id="titreField" GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="Titre du livre" styleClass="input-field" />

                <Label text="Catégorie *" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="field-label" />
                <TextField fx:id="categorieField" GridPane.rowIndex="2" GridPane.columnIndex="1" promptText="Catégorie" styleClass="input-field" />

                <Label text="Prix (TND) *" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="field-label" />
                <TextField fx:id="prixField" GridPane.rowIndex="3" GridPane.columnIndex="1" promptText="0.00" styleClass="input-field" />

                <Label text="Collection *" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="field-label" />
                <ComboBox fx:id="collectionComboBox" GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="1.7976931348623157E308" promptText="Sélectionner une collection" styleClass="input-field" />

                <Label text="Description *" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="field-label" />
                <TextArea fx:id="descriptionArea" GridPane.rowIndex="5" GridPane.columnIndex="1" prefRowCount="4" wrapText="true" promptText="Description détaillée du livre..." styleClass="input-field" />

                <Label text="Fichier PDF *" GridPane.rowIndex="6" GridPane.columnIndex="0" styleClass="field-label" />
                <HBox spacing="15.0" GridPane.rowIndex="6" GridPane.columnIndex="1" alignment="CENTER_LEFT">
                    <Button mnemonicParsing="false" onAction="#onChoosePdf" text="📄 Choisir PDF" styleClass="secondary-button" />
                    <Label fx:id="pdfLabel" text="Aucun fichier" styleClass="pdf-label" />
                </HBox>
            </GridPane>
        </VBox>
    </fx:define>
</VBox>
