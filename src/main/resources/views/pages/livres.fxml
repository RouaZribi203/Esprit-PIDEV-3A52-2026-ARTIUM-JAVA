<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane
        fitToWidth="true"
        hbarPolicy="NEVER"
        style="-fx-background-color: #f8fafc; -fx-background: #f8fafc;"
        xmlns="http://javafx.com/javafx/20.0.2"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="controllers.LivresController">

    <VBox spacing="20.0" style="-fx-padding: 32 36 40 36; -fx-background-color: #f8fafc;">

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- PAGE HEADER                                                     -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <HBox alignment="CENTER_LEFT" spacing="20.0"
              style="-fx-padding: 0 0 8 0;">
            <VBox spacing="4.0">
                <Label
                        text="📚 Gestion des Livres"
                        style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1f2937;" />
                <Label
                        text="Administrez le catalogue de la bibliothèque"
                        style="-fx-font-size: 13; -fx-text-fill: #6b7280;" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />

            <!-- Search + Actions -->
            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <TextField
                        fx:id="searchField"
                        prefWidth="300.0"
                        promptText="🔍  Rechercher par titre, catégorie ou auteur…"
                        style="-fx-padding: 11 16; -fx-font-size: 13; -fx-background-color: white;
                           -fx-border-color: #e5e7eb; -fx-border-radius: 10; -fx-background-radius: 10;
                           -fx-border-width: 1.5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 1);" />
                <Button
                        mnemonicParsing="false"
                        onAction="#onRefresh"
                        text="↺ Rafraîchir"
                        style="-fx-padding: 11 18; -fx-font-size: 12; -fx-font-weight: bold;
                           -fx-background-color: white; -fx-text-fill: #374151;
                           -fx-border-color: #d1d5db; -fx-border-radius: 10; -fx-background-radius: 10;
                           -fx-cursor: hand; -fx-border-width: 1.5;" />
                <Button
                        fx:id="addBookButton"
                        mnemonicParsing="false"
                        onAction="#onShowForm"
                        text="+ Ajouter un livre"
                        style="-fx-padding: 11 22; -fx-font-size: 13; -fx-font-weight: bold;
                           -fx-background-color: #6366f1; -fx-text-fill: white;
                           -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.35), 10, 0, 0, 3);" />
            </HBox>
        </HBox>

        <!-- Thin decorative separator -->
        <Region prefHeight="1.0"
                style="-fx-background-color: linear-gradient(to right, #6366f1, #06b6d4, #10b981);
                       -fx-opacity: 0.4;" />

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- BOOKS GRID                                                      -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <VBox spacing="14.0"
              style="-fx-background-color: white; -fx-border-radius: 16; -fx-background-radius: 16;
                     -fx-border-color: #f3f4f6; -fx-border-width: 1.5; -fx-padding: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);">

            <!-- Section label -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="📖"
                       style="-fx-font-size: 16; -fx-background-color: #ede9fe; -fx-padding: 6 10;
                              -fx-background-radius: 8;" />
                <Label text="Catalogue"
                       style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #374151;" />
            </HBox>

            <TilePane
                    fx:id="cardsTile"
                    hgap="18.0"
                    vgap="18.0"
                    prefColumns="3"
                    alignment="TOP_CENTER"
                    style="-fx-padding: 6 0 0 0;" />

            <!-- Pagination -->
            <HBox alignment="CENTER" spacing="16.0"
                  style="-fx-padding: 14 0 4 0; -fx-border-color: #f3f4f6; -fx-border-width: 1 0 0 0;">
                <Button
                        fx:id="prevPageBtn"
                        mnemonicParsing="false"
                        onAction="#onPrevPage"
                        text="◀  Précédent"
                        style="-fx-padding: 9 20; -fx-font-size: 12; -fx-font-weight: bold;
                           -fx-background-color: #f9fafb; -fx-text-fill: #374151;
                           -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-border-width: 1.5;" />
                <Label
                        fx:id="pageInfoLabel"
                        text="Page 1 / 1"
                        style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #6366f1;
                           -fx-background-color: #ede9fe; -fx-padding: 6 16; -fx-background-radius: 20;" />
                <Button
                        fx:id="nextPageBtn"
                        mnemonicParsing="false"
                        onAction="#onNextPage"
                        text="Suivant  ▶"
                        style="-fx-padding: 9 20; -fx-font-size: 12; -fx-font-weight: bold;
                           -fx-background-color: #f9fafb; -fx-text-fill: #374151;
                           -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-border-width: 1.5;" />
            </HBox>
        </VBox>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- STATISTICS DASHBOARD (fully dynamic from controller)           -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <VBox
                fx:id="statisticsContainer"
                spacing="18.0"
                VBox.vgrow="NEVER"
                style="-fx-padding: 8 0 0 0;" />

    </VBox>
</ScrollPane>
