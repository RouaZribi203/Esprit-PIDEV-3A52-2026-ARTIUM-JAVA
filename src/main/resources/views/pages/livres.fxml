<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox spacing="12.0" styleClass="page-root" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LivresController">
    <padding><Insets bottom="20.0" left="26.0" right="20.0" top="24.0" /></padding>

    <HBox alignment="CENTER_LEFT" spacing="16.0">
        <VBox spacing="2.0">
            <Label styleClass="page-title" text="Gestion des Livres" />
            <Label styleClass="page-subtitle" text="Admin Dashboard" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="searchField" prefWidth="220.0" promptText="Rechercher un livre..." styleClass="search-field" />
        <Button mnemonicParsing="false" onAction="#onSearch" text="🔍" styleClass="icon-btn" />
        <Button fx:id="addBookButton" mnemonicParsing="false" onAction="#onShowForm" styleClass="primary-button" text="+ Ajouter" />
    </HBox>

    <SplitPane dividerPositions="0.65" VBox.vgrow="ALWAYS">
        <items>
            <VBox spacing="10.0">
                <StackPane VBox.vgrow="ALWAYS">
                    <TableView fx:id="livresTable">
                        <columns>
                            <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                            <TableColumn fx:id="colCouverture" prefWidth="80.0" text="Couverture" />
                            <TableColumn fx:id="colTitre" prefWidth="200.0" text="Titre" />
                            <TableColumn fx:id="colAuteur" prefWidth="150.0" text="Auteur" />
                            <TableColumn fx:id="colCategorie" prefWidth="130.0" text="Catégorie" />
                            <TableColumn fx:id="colPrix" prefWidth="90.0" text="Prix" />
                            <TableColumn fx:id="colDisponibilite" prefWidth="110.0" text="Disponibilité" />
                            <TableColumn fx:id="colDetails" prefWidth="100.0" text="Actions" />
                        </columns>
                    </TableView>
                </StackPane>
            </VBox>

            <VBox fx:id="formPanel" spacing="0.0" styleClass="form-panel" prefWidth="400.0" visible="false">
                <padding><Insets top="0.0" right="24.0" bottom="24.0" left="24.0" /></padding>

                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="form-header">
                    <VBox spacing="2.0">
                        <Label fx:id="formTitleLabel" styleClass="form-title" text="Nouveau livre" />
                        <Label styleClass="form-subtitle" text="Remplissez les informations" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false" onAction="#onHideForm" text="✕" styleClass="close-btn" />
                </HBox>

                <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" styleClass="form-scroll">
                    <VBox spacing="16.0">
                        <GridPane hgap="12.0" vgap="12.0">
                            <columnConstraints>
                                <ColumnConstraints minWidth="100.0" prefWidth="100.0" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>

                            <Label text="Couverture" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="field-label" />
                            <HBox spacing="10.0" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                <StackPane styleClass="image-preview-container">
                                    <Rectangle width="70.0" height="45.0" styleClass="image-placeholder" />
                                    <ImageView fx:id="couvertureImageView" fitWidth="70.0" fitHeight="45.0" preserveRatio="true" />
                                </StackPane>
                                <Button mnemonicParsing="false" onAction="#onChooseImage" text="Parcourir" styleClass="secondary-button" />
                                <Label fx:id="couvertureLabel" text="" styleClass="file-name-label" />
                            </HBox>

                            <Label text="Titre *" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="field-label" />
                            <TextField fx:id="titreField" GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="Titre du livre" styleClass="input-field" />

                            <Label text="Catégorie *" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="field-label" />
                            <TextField fx:id="categorieField" GridPane.rowIndex="2" GridPane.columnIndex="1" promptText="Catégorie" styleClass="input-field" />

                            <Label text="Prix (TND) *" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="field-label" />
                            <TextField fx:id="prixField" GridPane.rowIndex="3" GridPane.columnIndex="1" promptText="0.00" styleClass="input-field" />

                            <Label text="Collection *" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="field-label" />
                            <ComboBox fx:id="collectionComboBox" GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="220.0" promptText="Sélectionner" styleClass="input-field" />

                            <Label text="Description *" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="field-label" />
                            <TextArea fx:id="descriptionArea" GridPane.rowIndex="5" GridPane.columnIndex="1" prefRowCount="3" wrapText="true" promptText="Description du livre..." styleClass="input-field" />

                            <Label text="PDF *" GridPane.rowIndex="6" GridPane.columnIndex="0" styleClass="field-label" />
                            <HBox spacing="10.0" GridPane.rowIndex="6" GridPane.columnIndex="1" alignment="CENTER_LEFT">
                                <Button mnemonicParsing="false" onAction="#onChoosePdf" text="📄 Choisir" styleClass="secondary-button" />
                                <Label fx:id="pdfLabel" text="Aucun fichier" styleClass="pdf-label" />
                            </HBox>
                        </GridPane>

                        <HBox spacing="10.0">
                            <Button fx:id="saveButton" mnemonicParsing="false" onAction="#onSave" styleClass="primary-button" text="✓ Enregistrer" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
                            <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#onDelete" styleClass="danger-button" text="🗑" disable="true" />
                        </HBox>

                        <Button mnemonicParsing="false" onAction="#onClear" styleClass="secondary-button" text="Vider le formulaire" maxWidth="1.7976931348623157E308" />
                    </VBox>
                </ScrollPane>
            </VBox>
        </items>
    </SplitPane>
</VBox>
