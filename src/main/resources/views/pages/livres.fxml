<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox spacing="16.0" styleClass="page-root" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LivresController">
    <padding><Insets bottom="24.0" left="28.0" right="24.0" top="28.0" /></padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <VBox spacing="4.0">
            <Label styleClass="page-title" text="Gestion des Livres" />
            <Label styleClass="page-subtitle" text="Administrez le catalogue de la bibliothèque" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <TextField fx:id="searchField" prefWidth="280.0" promptText="Rechercher par titre, catégorie ou auteur..." styleClass="search-field" />
            <Button mnemonicParsing="false" onAction="#onSearch" text="🔍" styleClass="icon-btn" />
            <Button fx:id="addBookButton" mnemonicParsing="false" onAction="#onShowForm" styleClass="primary-button" text="+ Ajouter un livre" />
        </HBox>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="cards-scroll">
        <TilePane fx:id="cardsTile" hgap="24.0" vgap="24.0" prefColumns="0" alignment="TOP_LEFT" />
    </ScrollPane>

    <!-- Hidden template for the popup form (not visible in main view) -->
    <fx:define>
        <VBox fx:id="formPanel" spacing="12.0" styleClass="popup-form-container" prefWidth="640.0">
            <padding><Insets top="18.0" right="20.0" bottom="18.0" left="20.0" /></padding>

            <Label fx:id="formTitleLabel" text="Ajouter un nouveau livre" styleClass="form-title" />
            <Label text="Remplissez les informations ci-dessous" styleClass="form-subtitle" />

            <HBox spacing="10.0">
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label text="Titre *" styleClass="field-label" />
                    <TextField fx:id="titreField" promptText="Titre du livre" styleClass="input-field" maxWidth="1.7976931348623157E308" />
                </VBox>
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label text="Catégorie *" styleClass="field-label" />
                    <TextField fx:id="categorieField" promptText="Catégorie" styleClass="input-field" maxWidth="1.7976931348623157E308" />
                </VBox>
            </HBox>

            <HBox spacing="10.0">
                <VBox spacing="6.0" HBox.hgrow="ALWAYS" minWidth="220.0">
                    <Label text="Prix (TND) *" styleClass="field-label" />
                    <TextField fx:id="prixField" promptText="0.00" styleClass="input-field" minWidth="210.0" maxWidth="1.7976931348623157E308" />
                </VBox>
                <VBox spacing="6.0" HBox.hgrow="ALWAYS" minWidth="220.0">
                    <Label text="Collection *" styleClass="field-label" />
                    <ComboBox fx:id="collectionComboBox" promptText="Sélectionner une collection" styleClass="input-field" minWidth="210.0" maxWidth="1.7976931348623157E308" prefWidth="1.7976931348623157E308" />
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Label text="Couverture" styleClass="field-label" />
                <StackPane styleClass="image-preview-container">
                    <Rectangle width="90.0" height="60.0" styleClass="image-placeholder" />
                    <ImageView fx:id="couvertureImageView" fitWidth="90.0" fitHeight="60.0" preserveRatio="true" />
                </StackPane>
                <Button mnemonicParsing="false" onAction="#onChooseImage" text="Parcourir" styleClass="secondary-button" />
                <Label fx:id="couvertureLabel" text="Aucun fichier" styleClass="file-name-label" />
            </HBox>

            <VBox spacing="6.0">
                <Label text="Description *" styleClass="field-label" />
                <TextArea fx:id="descriptionArea" prefRowCount="4" wrapText="true" promptText="Description détaillée du livre..." styleClass="input-field" maxWidth="1.7976931348623157E308" />
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Label text="Fichier PDF *" styleClass="field-label" />
                <Button mnemonicParsing="false" onAction="#onChoosePdf" text="📄 Choisir PDF" styleClass="secondary-button" />
                <Label fx:id="pdfLabel" text="Aucun fichier" styleClass="pdf-label" />
            </HBox>

            <Label fx:id="formErrorLabel" managed="false" visible="false" wrapText="true" styleClass="popup-error" />
        </VBox>
    </fx:define>
</VBox>
