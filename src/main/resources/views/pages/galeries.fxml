<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" styleClass="page-root" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.GaleriesController">
    <padding>
        <Insets bottom="18.0" left="18.0" right="18.0" top="16.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT">
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                <Label styleClass="page-title" text="Gestion des galeries" />
                <Label styleClass="page-subtitle" text="Recherche, filtre et gestion complete des galeries" />
            </VBox>
            <Button fx:id="addGalerieButton" mnemonicParsing="false" onAction="#onAddGalerieClick" styleClass="primary-action-button" text="Ajouter galerie" />
        </HBox>

        <VBox spacing="12.0" styleClass="list-card">
            <padding>
                <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <TextField fx:id="rechercheField" promptText="Rechercher galerie (nom, adresse, localisation...)" styleClass="gallery-search-field" HBox.hgrow="ALWAYS" />
                <Label text="Filtrer par" />
                <ComboBox fx:id="filtreComboBox" prefWidth="190.0" />
            </HBox>

            <Label fx:id="emptyStateLabel" styleClass="section-subtitle" text="Aucune galerie trouvee." visible="false" managed="false" />

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="gallery-scroll" VBox.vgrow="ALWAYS">
                <content>
                    <FlowPane fx:id="galeriesFlowPane" hgap="12.0" vgap="12.0" styleClass="gallery-flow">
                        <padding>
                            <Insets bottom="6.0" left="2.0" right="2.0" top="6.0" />
                        </padding>
                    </FlowPane>
                </content>
            </ScrollPane>
        </VBox>
    </children>
</VBox>

