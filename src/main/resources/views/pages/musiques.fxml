<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12.0" styleClass="page-root" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AdminMusiquesController">
    <padding>
        <Insets bottom="20.0" left="26.0" right="20.0" top="24.0" />
    </padding>

    <Label styleClass="page-title" text="Musiques" />
    <Label styleClass="page-subtitle" text="Consultation admin: lecture et suppression des musiques et playlists" />

    <HBox spacing="10.0">
        <Button fx:id="musiqueSectionButton" mnemonicParsing="false" onAction="#handleShowMusiqueSection" text="Musiques" />
        <Button fx:id="playlistsSectionButton" mnemonicParsing="false" onAction="#handleShowPlaylistsSection" text="Playlists" />
    </HBox>

    <HBox fx:id="musicSearchBar" spacing="10.0">
        <TextField fx:id="searchField" HBox.hgrow="ALWAYS" onAction="#handleSearch" promptText="Titre, description, genre" />
        <Button mnemonicParsing="false" onAction="#handleSearch" text="Rechercher" />
        <Button mnemonicParsing="false" onAction="#handleClearSearch" text="Effacer" />
        <ComboBox fx:id="sortMusicComboBox" prefWidth="170.0" promptText="Tri" />
    </HBox>

    <HBox fx:id="playlistSearchBar" spacing="10.0" visible="false" managed="false">
        <TextField fx:id="playlistSearchField" HBox.hgrow="ALWAYS" onAction="#handleSearchPlaylist" promptText="Nom, description" />
        <Button mnemonicParsing="false" onAction="#handleSearchPlaylist" text="Rechercher" />
        <Button mnemonicParsing="false" onAction="#handleClearPlaylistSearch" text="Effacer" />
        <ComboBox fx:id="sortPlaylistComboBox" prefWidth="170.0" promptText="Tri" />
    </HBox>

    <VBox fx:id="musiqueSection" spacing="8.0">
        <Label text="Toutes les musiques" />
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="380.0">
            <content>
                <VBox spacing="12.0">
                    <TilePane fx:id="musicGrid" hgap="12.0" prefColumns="4" vgap="12.0" />
                    <Label fx:id="emptyListLabel" styleClass="section-subtitle" text="Aucune musique disponible." wrapText="true" />
                </VBox>
            </content>
        </ScrollPane>

        <VBox spacing="6.0" style="-fx-background-color: #171717; -fx-background-radius: 8; -fx-padding: 12;">
            <Label style="-fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold;" text="Lecture en cours" />
            <Label fx:id="nowPlayingTitleLabel" style="-fx-text-fill: #ffffff;" text="Selectionnez une musique" wrapText="true" />
            <Label fx:id="nowPlayingMetaLabel" style="-fx-text-fill: #b0b0b0;" text="Genre: -" />
            <HBox spacing="10.0">
                <Button mnemonicParsing="false" onAction="#handlePreviousTrack" text="Prev" />
                <Button fx:id="playPauseButton" mnemonicParsing="false" onAction="#handlePlayPause" text="Play" />
                <Button mnemonicParsing="false" onAction="#handleNextTrack" text="Next" />
                <Label fx:id="playerStatusLabel" style="-fx-text-fill: #a0a0a0;" text="Pret" />
            </HBox>
        </VBox>
    </VBox>

    <VBox fx:id="playlistsSection" spacing="10.0" visible="false" managed="false">
        <Label text="Toutes les playlists" />

        <VBox fx:id="playlistDetailSection" spacing="8.0" visible="false" managed="false" style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 8; -fx-padding: 12;">
            <HBox spacing="10.0">
                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="playlistDetailTitleLabel" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" text="Aucune playlist selectionnee" />
                    <Label fx:id="playlistDetailMetaLabel" style="-fx-text-fill: #cbd5e1;" text="Cliquez sur une playlist pour voir ses musiques." wrapText="true" />
                </VBox>
                <Button mnemonicParsing="false" onAction="#handleClosePlaylistDetail" text="Fermer" />
            </HBox>

            <Label fx:id="playlistSongsEmptyLabel" styleClass="section-subtitle" text="Aucune musique dans cette playlist." wrapText="true" />
            <VBox fx:id="playlistSongsBox" spacing="8.0" />
        </VBox>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="430.0">
            <content>
                <VBox spacing="12.0">
                    <TilePane fx:id="playlistGrid" hgap="12.0" prefColumns="3" vgap="12.0" />
                    <Label fx:id="playlistEmptyListLabel" styleClass="section-subtitle" text="Aucune playlist disponible." wrapText="true" />
                </VBox>
            </content>
        </ScrollPane>
    </VBox>
</VBox>

