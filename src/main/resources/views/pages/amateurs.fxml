<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" styleClass="page-root users-shell" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AmateursBackofficeController">
    <padding>
        <Insets bottom="20.0" left="26.0" right="20.0" top="24.0" />
    </padding>
    <VBox spacing="14.0" styleClass="users-panel list-card">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="users-header">
            <Label styleClass="page-title users-title" text="Gestion des amateurs" />
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#onAddUser" styleClass="primary-action-button" text="Ajouter amateur" />
        </HBox>

        <TextField fx:id="searchField" HBox.hgrow="ALWAYS" promptText="Rechercher amateur (nom, email, ville)" styleClass="table-search" />

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="users-scroll" VBox.vgrow="ALWAYS">
            <content>
                <FlowPane fx:id="cardsContainer" hgap="18.0" prefWrapLength="1180.0" styleClass="users-cards-grid" vgap="18.0" />
            </content>
        </ScrollPane>
    </VBox>
</VBox>

