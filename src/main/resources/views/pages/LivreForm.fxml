<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox spacing="16.0" styleClass="popup-form-container" style="-fx-padding: 24; -fx-background-color: linear-gradient(to bottom, #ffffff, #f9fafb);" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LivreFormController">

    <!-- Header -->
    <VBox spacing="4.0" style="-fx-padding: 0 0 16 0; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
        <Label fx:id="formTitleLabel" styleClass="form-title" text="Ajouter un livre" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;" />
        <Label styleClass="form-subtitle" text="Renseignez les détails du livre pour enrichir la bibliothèque" style="-fx-font-size: 13; -fx-text-fill: #6b7280;" />
    </VBox>

    <!-- Main Form Content -->
    <VBox spacing="16.0">

        <!-- Row 1: Titre et Catégorie -->
        <HBox spacing="12.0">
            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                <Label text="📖 Titre *" styleClass="field-label" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1f2937;" />
                <TextField fx:id="titreField" promptText="Titre du livre" styleClass="input-field" style="-fx-padding: 10; -fx-font-size: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 6; -fx-background-radius: 6; -fx-border-width: 1; -fx-focus-color: #3b82f6; -fx-faint-focus-color: #dbeafe;" />
            </VBox>
            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                <Label text="📚 Catégorie *" styleClass="field-label" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1f2937;" />
                <TextField fx:id="categorieField" promptText="Catégorie (ex: Roman, Science-fiction)" styleClass="input-field" style="-fx-padding: 10; -fx-font-size: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 6; -fx-background-radius: 6; -fx-border-width: 1; -fx-focus-color: #3b82f6; -fx-faint-focus-color: #dbeafe;" />
            </VBox>
        </HBox>

        <!-- Row 2: Prix et Collection -->
        <HBox spacing="12.0">
            <VBox spacing="8.0" HBox.hgrow="ALWAYS" minWidth="220.0">
                <Label text="💰 Prix de location (TND) *" styleClass="field-label" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1f2937;" />
                <TextField fx:id="prixField" promptText="0.00" styleClass="input-field" minWidth="210.0" style="-fx-padding: 10; -fx-font-size: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 6; -fx-background-radius: 6; -fx-border-width: 1; -fx-focus-color: #3b82f6; -fx-faint-focus-color: #dbeafe;" />
            </VBox>
            <VBox spacing="8.0" HBox.hgrow="ALWAYS" minWidth="220.0">
                <Label text="🏷️ Collection *" styleClass="field-label" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1f2937;" />
                <ComboBox fx:id="collectionComboBox" promptText="Sélectionner une collection" styleClass="input-field" minWidth="210.0" style="-fx-padding: 10; -fx-font-size: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 6; -fx-background-radius: 6; -fx-border-width: 1; -fx-focus-color: #3b82f6; -fx-faint-focus-color: #dbeafe;" />
            </VBox>
        </HBox>

        <!-- Image Selection with Premium Design -->
        <VBox spacing="8.0" style="-fx-padding: 12; -fx-background-color: #f3f4f6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-width: 1;">
            <Label text="🖼️ Image de couverture *" styleClass="field-label" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1f2937;" />
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <StackPane style="-fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-background-radius: 8; -fx-background-color: white;">
                    <Rectangle width="100.0" height="140.0" styleClass="image-placeholder" style="-fx-fill: #f9fafb; -fx-stroke: #d1d5db; -fx-stroke-width: 2; -fx-stroke-dash-array: 5 5;" />
                    <ImageView fx:id="couvertureImageView" fitWidth="100.0" fitHeight="140.0" preserveRatio="true" />
                </StackPane>
                <VBox spacing="6.0">
                    <Button mnemonicParsing="false" onAction="#onChooseImageClick" style="-fx-padding: 10 20; -fx-font-size: 12; -fx-background-color: #3b82f6; -fx-text-fill: white; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;" text="📂 Choisir une image" />
                    <Label fx:id="couvertureLabel" styleClass="file-name-label" text="Aucun fichier choisi" wrapText="true" style="-fx-font-size: 11; -fx-text-fill: #6b7280; -fx-font-style: italic;" />
                </VBox>
            </HBox>
        </VBox>

        <!-- Description -->
        <VBox spacing="8.0">
            <Label text="✏️ Description *" styleClass="field-label" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1f2937;" />
            <TextArea fx:id="descriptionArea" prefRowCount="5" promptText="Écrivez une description attrayante du livre..." styleClass="input-field" wrapText="true" style="-fx-padding: 10; -fx-font-size: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 6; -fx-background-radius: 6; -fx-border-width: 1; -fx-focus-color: #3b82f6; -fx-faint-focus-color: #dbeafe; -fx-control-inner-background: white;" />
        </VBox>

        <!-- PDF Selection with Premium Design -->
        <VBox spacing="8.0" style="-fx-padding: 12; -fx-background-color: #f3f4f6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-width: 1;">
            <Label text="📄 Fichier PDF *" styleClass="field-label" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1f2937;" />
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Button mnemonicParsing="false" onAction="#onChoosePdfClick" style="-fx-padding: 10 20; -fx-font-size: 12; -fx-background-color: #10b981; -fx-text-fill: white; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;" text="📁 Sélectionner PDF" />
                <Label fx:id="pdfLabel" styleClass="pdf-label" text="Aucun fichier choisi" wrapText="true" style="-fx-font-size: 11; -fx-text-fill: #6b7280; -fx-font-style: italic;" />
            </HBox>
        </VBox>

        <!-- Error Message -->
        <Label fx:id="validationErrorLabel" managed="false" styleClass="popup-error" visible="false" wrapText="true" style="-fx-font-size: 12; -fx-text-fill: #dc2626; -fx-padding: 10; -fx-background-color: #fee2e2; -fx-border-color: #fca5a5; -fx-border-radius: 6; -fx-background-radius: 6;" />
    </VBox>

    <!-- Footer with Action Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0" style="-fx-padding: 16 0 0 0; -fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0;">
        <Button mnemonicParsing="false" onAction="#onCancelClick" style="-fx-padding: 10 24; -fx-font-size: 12; -fx-background-color: #e5e7eb; -fx-text-fill: #374151; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;" text="❌ Fermer" />
        <Button mnemonicParsing="false" onAction="#onSaveClick" style="-fx-padding: 10 24; -fx-font-size: 12; -fx-background-color: #0ea5e9; -fx-text-fill: white; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;" text="✅ Enregistrer" />
    </HBox>
</VBox>



