<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fx:controller="controllers.ProfileController"
            xmlns:fx="http://javafx.com/fxml"
            fitToWidth="true"
            hbarPolicy="NEVER"
            styleClass="profile-scroll"
            stylesheets="@../styles/profile.css">

    <VBox styleClass="profile-root" alignment="TOP_CENTER" spacing="10">

        <!-- ═════════ HERO ═════════ -->
        <StackPane styleClass="profile-hero" maxWidth="900">


            <!-- Avatar -->
            <VBox alignment="CENTER">
                <StackPane styleClass="avatar-ring-outer"
                           prefWidth="120" prefHeight="120">

                    <!-- cercle fond -->
                    <Circle fx:id="avatarPlaceholder"
                            radius="55"
                            styleClass="avatar-placeholder"/>

                    <!-- initiale -->
                    <Label fx:id="avatarInitial"
                           text="A"
                           styleClass="avatar-initial"/>

                    <!-- image -->
                    <ImageView fx:id="profileAvatar"
                               fitWidth="110" fitHeight="110"
                               preserveRatio="false"
                               visible="false">
                        <clip>
                            <Circle radius="55" centerX="55" centerY="55"/>
                        </clip>
                    </ImageView>

                </StackPane>
            </VBox>

            <!-- Edit Photo -->
            <Button fx:id="editPhotoBtn"
                    text="📷"
                    styleClass="edit-photo-btn"
                    onAction="#onEditPhoto"
                    StackPane.alignment="TOP_RIGHT">
                <StackPane.margin>
                    <Insets top="15" right="20"/>
                </StackPane.margin>
            </Button>

        </StackPane>

        <!-- ═════════ PROFILE INFO ═════════ -->
        <VBox alignment="CENTER" spacing="8" maxWidth="800"
              styleClass="profile-identity">

            <Label fx:id="fullNameLabel"
                   styleClass="profile-fullname"
                   text="Nom Prénom"/>

            <Label fx:id="roleLabel"
                   styleClass="profile-role-badge"
                   text="ADMIN"/>

            <HBox alignment="CENTER" spacing="15">
                <Label fx:id="villeLabel" styleClass="meta-chip" text="📍 Tunis"/>
                <Label fx:id="emailLabel" styleClass="meta-chip" text="✉ email@mail.com"/>
                <Label fx:id="telLabel" styleClass="meta-chip" text="☏ 00000000"/>
            </HBox>

        </VBox>

        <!-- ═════════ STATS ═════════ -->
        <HBox styleClass="stats-row"
              alignment="CENTER"
              spacing="20"
              maxWidth="800">

            <VBox styleClass="stat-card" alignment="CENTER">
                <Label fx:id="statOeuvres" styleClass="stat-number" text="0"/>
                <Label styleClass="stat-label" text="Œuvres"/>
            </VBox>

            <VBox styleClass="stat-card" alignment="CENTER">
                <Label fx:id="statDays" styleClass="stat-number" text="0"/>
                <Label styleClass="stat-label" text="Jours membre"/>
            </VBox>

            <VBox styleClass="stat-card" alignment="CENTER">
                <HBox alignment="CENTER" spacing="6">
                    <Circle fx:id="statutDot" radius="6" styleClass="statut-dot-actif"/>
                    <Label fx:id="statStatut" styleClass="stat-statut" text="Actif"/>
                </HBox>
                <Label styleClass="stat-label" text="Statut"/>
            </VBox>

        </HBox>

        <!-- ═════════ MAIN CONTENT ═════════ -->
        <HBox spacing="30"
              alignment="TOP_CENTER"
              maxWidth="900"
              styleClass="profile-content-grid">

            <!-- LEFT -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">

                <!-- BIO -->
                <VBox styleClass="info-card">
                    <Label text="BIOGRAPHIE" styleClass="card-section-title"/>
                    <Label fx:id="bioLabel"
                           text="Votre biographie ici..."
                           wrapText="true"
                           styleClass="card-body-text"/>
                </VBox>

            </VBox>

            <!-- RIGHT -->
            <VBox spacing="20" prefWidth="280">

                <!-- INFOS -->
                <VBox styleClass="info-card">

                    <Label text="INFORMATIONS" styleClass="card-section-title"/>

                    <GridPane hgap="10" vgap="10">

                        <columnConstraints>
                            <ColumnConstraints minWidth="100"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="Prénom" styleClass="info-key"
                               GridPane.rowIndex="0"/>
                        <Label fx:id="prenomVal" text="—"
                               styleClass="info-val"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Nom" styleClass="info-key"
                               GridPane.rowIndex="1"/>
                        <Label fx:id="nomVal" text="—"
                               styleClass="info-val"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Naissance" styleClass="info-key"
                               GridPane.rowIndex="2"/>
                        <Label fx:id="naissanceVal" text="—"
                               styleClass="info-val"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Inscription" styleClass="info-key"
                               GridPane.rowIndex="3"/>
                        <Label fx:id="inscriptionVal" text="—"
                               styleClass="info-val"
                               GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label text="Spécialité" styleClass="info-key"
                               GridPane.rowIndex="4"/>
                        <Label fx:id="specialiteVal" text="—"
                               styleClass="info-val"
                               GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    </GridPane>

                </VBox>

                <!-- BUTTON -->
                <Button fx:id="editProfileBtn"
                        text="MODIFIER LE PROFIL"
                        maxWidth="Infinity"
                        styleClass="btn-edit-profile"
                        onAction="#onEditProfile"/>

            </VBox>

        </HBox>

    </VBox>

</ScrollPane>