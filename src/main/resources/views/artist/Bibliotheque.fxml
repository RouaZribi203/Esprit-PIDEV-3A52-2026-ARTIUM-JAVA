<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<VBox spacing="12.0" styleClass="page-root collections-page" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.artist.BibliothequArtisteController">
    <padding><Insets bottom="12.0" left="12.0" right="12.0" top="12.0" /></padding>
    
    <VBox spacing="10.0" styleClass="collections-body-card" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="16.0" left="20.0" right="20.0" top="16.0" /></padding>

        <HBox alignment="CENTER_LEFT" spacing="16.0">
            <Label styleClass="page-title-small" text="Ma Bibliothèque" />
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" prefWidth="220.0" promptText="Rechercher un livre..." styleClass="search-field" onAction="#onSearch" />
            <Button mnemonicParsing="false" onAction="#onSearch" text="🔍" styleClass="icon-btn" />
            <Button fx:id="addBookButton" mnemonicParsing="false" onAction="#onShowForm" styleClass="primary-button" text="+ Ajouter un livre" />
        </HBox>

        <HBox spacing="20.0" VBox.vgrow="ALWAYS" alignment="TOP_LEFT">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" styleClass="cards-scroll">
                <TilePane fx:id="cardsTile" hgap="18.0" vgap="18.0" orientation="HORIZONTAL" alignment="TOP_LEFT" prefTileWidth="240.0" />
            </ScrollPane>

            <StackPane fx:id="formStack" visible="false" managed="false">
                <VBox fx:id="formPanel" spacing="0.0" styleClass="form-panel" prefWidth="420.0">
                    <padding><Insets top="0.0" right="24.0" bottom="24.0" left="24.0" /></padding>

                    <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="form-header">
                        <VBox spacing="2.0">
                            <Label fx:id="formTitleLabel" styleClass="form-title" text="Nouveau livre" />
                            <Label styleClass="form-subtitle" text="Remplissez les informations du livre" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#onHideForm" text="✕" styleClass="close-btn" />
                    </HBox>

                    <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" styleClass="form-scroll">
                        <VBox spacing="16.0">
                            <GridPane hgap="14.0" vgap="14.0">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="110.0" prefWidth="110.0" />
                                    <ColumnConstraints hgrow="ALWAYS" />
                                </columnConstraints>

                                <Label text="Image" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="field-label" />
                                <HBox spacing="12.0" GridPane.rowIndex="0" GridPane.columnIndex="1" alignment="CENTER_LEFT">
                                    <StackPane styleClass="image-preview-container">
                                        <Rectangle width="90.0" height="60.0" styleClass="image-placeholder" />
                                        <ImageView fx:id="bookImageView" fitWidth="90.0" fitHeight="60.0" preserveRatio="true" />
                                    </StackPane>
                                    <Button fx:id="chooseImageButton" mnemonicParsing="false" onAction="#onChooseImage" text="Parcourir" styleClass="secondary-button" />
                                    <Button fx:id="generateImageButton" mnemonicParsing="false" onAction="#onGenerateImage" text="Génération image 🎨" styleClass="secondary-button" />
                                </HBox>

                                <Label text="Titre *" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="field-label" />
                                <TextField fx:id="titreField" GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="Titre du livre" styleClass="input-field" />

                                <Label text="Catégorie *" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="field-label" />
                                <TextField fx:id="categorieField" GridPane.rowIndex="2" GridPane.columnIndex="1" promptText="Catégorie du livre" styleClass="input-field" />

                                <Label text="Prix (TND) *" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="field-label" />
                                <TextField fx:id="prixField" GridPane.rowIndex="3" GridPane.columnIndex="1" promptText="0.00" styleClass="input-field" />

                                <Label text="Collection *" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="field-label" />
                                <ComboBox fx:id="collectionComboBox" GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="240.0" promptText="Ma collection" styleClass="input-field" />

                                <Label text="Description *" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="field-label" />
                                <TextArea fx:id="descriptionArea" GridPane.rowIndex="5" GridPane.columnIndex="1" prefRowCount="4" wrapText="true" promptText="Décrivez le contenu du livre..." styleClass="input-field" />

                                <Label text="Fichier PDF *" GridPane.rowIndex="6" GridPane.columnIndex="0" styleClass="field-label" />
                                <HBox spacing="10.0" GridPane.rowIndex="6" GridPane.columnIndex="1" alignment="CENTER_LEFT">
                                    <Button mnemonicParsing="false" onAction="#onChoosePdf" text="📄 Choisir un PDF" styleClass="secondary-button" />
                                    <Label fx:id="pdfLabel" text="Aucun fichier sélectionné" styleClass="pdf-label" />
                                </HBox>
                            </GridPane>

                            <Region prefHeight="8.0" />

                            <HBox spacing="12.0">
                                <Button fx:id="saveButton" mnemonicParsing="false" onAction="#onSave" styleClass="primary-button" text="✓ Publier le livre" maxWidth="1.7976931348623157E308" />
                                <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#onDelete" styleClass="danger-button" text="🗑 Supprimer" disable="true" />
                            </HBox>
                        </VBox>
                    </ScrollPane>
                </VBox>
            </StackPane>
        </HBox>
    </VBox>
</VBox>
