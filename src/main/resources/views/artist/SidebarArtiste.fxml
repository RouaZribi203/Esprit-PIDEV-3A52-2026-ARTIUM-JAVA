<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="320.0" spacing="14.0" styleClass="artist-right-column" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.artist.SidebarArtisteController">
    <VBox spacing="10.0" styleClass="artist-card">
        <padding>
            <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
        </padding>
        <Label styleClass="card-title" text="A propos" />
        <Label fx:id="bioLabel" styleClass="card-text" text="hello" wrapText="true" />
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <Label styleClass="card-label" text="Ne(e):" />
            <Label fx:id="dateNaissanceLabel" styleClass="card-text" text="-" />
        </HBox>
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <Label styleClass="card-label" text="Inscrit le:" />
            <Label fx:id="dateInscriptionLabel" styleClass="card-text" text="-" />
        </HBox>
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <Label styleClass="card-label" text="Email:" />
            <Label fx:id="emailLabel" styleClass="card-text" text="-" />
        </HBox>
        <StackPane prefHeight="64.0" prefWidth="64.0" styleClass="sidebar-avatar">
            <ImageView fx:id="profileImageView" fitHeight="58.0" fitWidth="58.0" pickOnBounds="true" preserveRatio="false" styleClass="sidebar-avatar-image" visible="false" />
            <Label fx:id="avatarFallbackLabel" styleClass="sidebar-avatar-symbol" text="🎨" />
        </StackPane>
    </VBox>

    <VBox spacing="10.0" styleClass="artist-card">
        <padding>
            <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
        </padding>
        <Label styleClass="card-title" text="Statistiques" />

        <HBox alignment="CENTER_LEFT" spacing="8.0"><Label styleClass="card-text" text="Oeuvres ajoutees" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="oeuvresCountLabel" styleClass="badge-primary" text="0" /></HBox>
        <HBox alignment="CENTER_LEFT" spacing="8.0"><Label styleClass="card-text" text="Reclamations faites" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="reclamationsCountLabel" styleClass="badge-warning" text="0" /></HBox>
        <HBox alignment="CENTER_LEFT" spacing="8.0"><Label styleClass="card-text" text="Evenements crees" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="evenementsCountLabel" styleClass="badge-info" text="0" /></HBox>
        <HBox alignment="CENTER_LEFT" spacing="8.0"><Label styleClass="card-text" text="Commentaires recus" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="commentsCountLabel" styleClass="badge-success" text="0" /></HBox>
        <HBox alignment="CENTER_LEFT" spacing="8.0"><Label styleClass="card-text" text="Likes recus" /><Region HBox.hgrow="ALWAYS" /><Label fx:id="likesCountLabel" styleClass="badge-danger" text="0" /></HBox>
    </VBox>
</VBox>

