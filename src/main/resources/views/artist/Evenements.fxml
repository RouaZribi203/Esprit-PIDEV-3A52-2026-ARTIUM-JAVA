<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12.0" styleClass="artist-card page-root" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.artist.EvenementsArtisteController">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label styleClass="page-title-small" text="Mes evenements" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="addEvenementButton" mnemonicParsing="false" onAction="#onAddEvenementClick" styleClass="artist-primary-button" text="Ajouter" />
    </HBox>

    <Label styleClass="page-subtitle-small" text="Gerez vos evenements et leur statut." wrapText="true" />

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <TextField fx:id="rechercheField" promptText="Rechercher evenement..." styleClass="artist-form-field" HBox.hgrow="ALWAYS" />
        <Label text="Trier par" />
        <ComboBox fx:id="triComboBox" prefWidth="220.0" styleClass="artist-form-combo" />
    </HBox>

    <Label fx:id="emptyStateLabel" managed="false" styleClass="page-subtitle-small" text="Aucun evenement trouve." visible="false" />

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="artist-events-scroll" VBox.vgrow="ALWAYS">
        <VBox fx:id="eventsListContainer" spacing="10.0" styleClass="artist-events-list">
            <padding>
                <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
            </padding>
        </VBox>
    </ScrollPane>
</VBox>

