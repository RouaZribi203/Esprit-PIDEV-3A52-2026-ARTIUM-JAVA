<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12.0" styleClass="artist-form-root" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.artist.EvenementArtisteFormController">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
    </padding>

    <Label fx:id="formTitleLabel" styleClass="page-title-small" text="Ajouter un evenement" />
    <Label styleClass="page-subtitle-small" text="Renseignez les details" />

    <HBox spacing="10.0">
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label text="Titre *" />
            <TextField fx:id="titreField" promptText="Titre" styleClass="artist-form-field" />
        </VBox>
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label text="Type *" />
            <ComboBox fx:id="typeComboBox" styleClass="artist-form-combo" />
        </VBox>
    </HBox>

    <HBox spacing="10.0">
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label text="Date debut *" />
            <TextField fx:id="dateDebutField" promptText="dd/MM/yyyy HH:mm" styleClass="artist-form-field" />
        </VBox>
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label text="Date fin *" />
            <TextField fx:id="dateFinField" promptText="dd/MM/yyyy HH:mm" styleClass="artist-form-field" />
        </VBox>
    </HBox>

    <HBox spacing="10.0">
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label text="Capacite max" />
            <TextField fx:id="capaciteField" promptText="Ex: 120" styleClass="artist-form-field" />
        </VBox>
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label text="Prix ticket" />
            <TextField fx:id="prixField" promptText="Ex: 25.0" styleClass="artist-form-field" />
        </VBox>
    </HBox>

    <VBox spacing="6.0">
        <Label text="Galerie *" />
        <ComboBox fx:id="galerieComboBox" styleClass="artist-form-combo" />
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <Label text="Image de couverture" />
        <Button mnemonicParsing="false" onAction="#onChooseImageClick" styleClass="artist-secondary-button" text="Choisir image" />
        <Label fx:id="imageFileLabel" styleClass="page-subtitle-small" text="Aucun fichier choisi" wrapText="true" />
    </HBox>

    <VBox spacing="6.0">
        <Label text="Description" />
        <TextArea fx:id="descriptionArea" prefRowCount="4" promptText="Description" styleClass="artist-form-text-area" wrapText="true" />
    </VBox>

    <Label fx:id="validationErrorLabel" managed="false" styleClass="artist-form-error" visible="false" wrapText="true" />

    <HBox alignment="CENTER_RIGHT" spacing="8.0">
        <Button mnemonicParsing="false" onAction="#onCancelClick" prefWidth="120.0" styleClass="artist-secondary-button" text="Fermer" />
        <Button mnemonicParsing="false" onAction="#onSaveClick" prefWidth="120.0" styleClass="artist-primary-button" text="Enregistrer" />
    </HBox>
</VBox>

