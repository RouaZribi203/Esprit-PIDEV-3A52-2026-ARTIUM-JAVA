<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0" styleClass="page-root collections-page" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.artist.MesOeuvresController">
    <padding><Insets bottom="12.0" left="12.0" right="12.0" top="12.0" /></padding>

    <VBox alignment="CENTER" maxWidth="860.0" spacing="10.0" styleClass="collections-body-card" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="12.0" left="12.0" right="12.0" top="12.0" /></padding>

        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="collections-toolbar">
            <StackPane styleClass="collections-search-wrap">
                <TextField fx:id="searchField" minWidth="320.0" prefHeight="34.0" prefWidth="320.0" maxWidth="320.0" promptText="Rechercher par titre ou collection" styleClass="collections-search-field" />
                <Label mouseTransparent="true" styleClass="collections-search-icon" text="⌕" StackPane.alignment="CENTER_RIGHT" />
            </StackPane>

            <Label styleClass="page-subtitle-small" text="Trier par" />
            <ComboBox fx:id="sortCombo" prefWidth="190.0" promptText="Commentaires" styleClass="oeuvres-select" />

            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="addOeuvreButton" mnemonicParsing="false" onAction="#onAddOeuvreClick" styleClass="collections-add-button" text="Ajouter une Oeuvre" />
        </HBox>

        <Label fx:id="emptyStateLabel" styleClass="page-subtitle-small" text="Chargement des oeuvres..." wrapText="true" />

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER" styleClass="oeuvres-feed-scroll" VBox.vgrow="ALWAYS">
            <VBox fx:id="oeuvresContainer" alignment="CENTER" fillWidth="false" spacing="12.0" styleClass="oeuvres-feed-list" />
        </ScrollPane>
    </VBox>
</VBox>
