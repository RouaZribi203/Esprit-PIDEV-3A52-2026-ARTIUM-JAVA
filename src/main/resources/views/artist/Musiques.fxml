<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" styleClass="artist-card page-root" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.artist.MusiquesController">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
    </padding>

    <Label styleClass="page-title-small" text="Ajouter une nouvelle musique" />

    <VBox spacing="6.0">
        <Label text="Titre *" />
        <TextField fx:id="titreField" promptText="entrez le titre de la musique" />
        <Label text="3-255 caractères" style="-fx-text-fill: #a0a0a0;" />
    </VBox>

    <VBox spacing="6.0">
        <Label text="Description *" />
        <TextArea fx:id="descriptionArea" prefRowCount="5" promptText="entrez la description de la musique" wrapText="true" />
        <Label text="10-5000 caractères" style="-fx-text-fill: #a0a0a0;" />
    </VBox>

    <VBox spacing="6.0">
        <Label text="Genre *" />
        <ComboBox fx:id="genreComboBox" promptText="Sélectionnez un genre" />
    </VBox>

    <VBox spacing="6.0">
        <Label text="Collection *" />
        <ComboBox fx:id="collectionComboBox" promptText="Sélectionnez une collection" />
    </VBox>

    <VBox spacing="6.0">
        <Label text="Image de Couverture" />
        <HBox spacing="10.0">
            <TextField fx:id="imagePathField" editable="false" promptText="Cliquez pour parcourir" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleChooseImage" text="Parcourir" />
        </HBox>
        <Label text="Max 5MB (JPEG, PNG)" style="-fx-text-fill: #a0a0a0;" />
    </VBox>

    <VBox spacing="6.0">
        <Label text="Fichier Audio *" />
        <HBox spacing="10.0">
            <TextField fx:id="audioPathField" editable="false" promptText="Cliquez pour parcourir" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleChooseAudio" text="Parcourir" />
        </HBox>
        <Label text="MP3, WAV, AAC" style="-fx-text-fill: #a0a0a0;" />
    </VBox>

    <Button mnemonicParsing="false" onAction="#handleCreateMusique" text="Créer" />
    <Label fx:id="feedbackLabel" wrapText="true" />
</VBox>

