<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox alignment="CENTER_LEFT" prefHeight="66.0" spacing="10.0" styleClass="navbar" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.NavbarController">
    <padding>
        <Insets bottom="10.0" left="16.0" right="16.0" top="10.0" />
    </padding>

    <Button fx:id="sidebarToggleButton" mnemonicParsing="false" onAction="#onSidebarToggle" prefHeight="34.0" prefWidth="34.0" styleClass="icon-button" text="=" />
    <Region HBox.hgrow="ALWAYS" />

    <MenuButton fx:id="themeMenuButton" mnemonicParsing="false" prefHeight="34.0" styleClass="menu-icon-button" text="Theme">
        <items>
            <MenuItem fx:id="lightThemeItem" mnemonicParsing="false" onAction="#onThemeLight" text="Clair" />
            <MenuItem fx:id="darkThemeItem" mnemonicParsing="false" onAction="#onThemeDark" text="Sombre" />
        </items>
    </MenuButton>

    <Button fx:id="notificationsButton" mnemonicParsing="false" onAction="#onNotificationsClick" prefHeight="34.0" prefWidth="34.0" styleClass="icon-button" text="!" />

    <MenuButton fx:id="userMenuButton" mnemonicParsing="false" prefHeight="34.0" styleClass="avatar-menu" text="Admin">
        <items>
            <MenuItem mnemonicParsing="false" onAction="#onSwitchToAdminView" text="Mode admin" />
            <MenuItem mnemonicParsing="false" onAction="#onSwitchToArtistView" text="Mode artiste" />
            <MenuItem mnemonicParsing="false" onAction="#onSwitchToAmateurView" text="Mode amateur" />
            <MenuItem mnemonicParsing="false" onAction="#onProfileClick" text="Profil" />
            <MenuItem mnemonicParsing="false" onAction="#onLogoutClick" text="Se deconnecter" />
        </items>
    </MenuButton>
</HBox>
