<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/20.0.2"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.SignUpController"
      prefHeight="720" prefWidth="1100"
      styleClass="signup-root">

    <fx:define>
        <ToggleGroup fx:id="roleGroup"/>
    </fx:define>

    <!-- ═══════════════════════════════════════════════════════
         LEFT PANEL — Branding / Hero
    ═══════════════════════════════════════════════════════════ -->
    <VBox styleClass="signup-left" alignment="CENTER" spacing="18" HBox.hgrow="NEVER">
        <padding>
            <Insets top="60" right="50" bottom="60" left="50"/>
        </padding>

        <!-- Logo mark -->
        <Label text="✦" styleClass="brand-star"/>
        <Label text="ARTIUM" styleClass="brand-logo"/>
        <Label text="Your Creative Universe" styleClass="brand-tagline"/>
        <Label text="Rejoignez une communauté d'artistes, d'amateurs d'art et de passionnés. Découvrez, partagez et célébrez la créativité."
               wrapText="true" styleClass="brand-description" maxWidth="340"/>

        <!-- Divider -->
        <Region prefHeight="1" maxWidth="200" styleClass="brand-divider"/>

        <!-- Feature list -->
        <VBox spacing="14">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="🎨" styleClass="feature-icon"/>
                <Label text="Découvrez des œuvres d'artistes talentueux" styleClass="feature-item"/>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="🎵" styleClass="feature-icon"/>
                <Label text="Explorez musiques et collections audio" styleClass="feature-item"/>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="📚" styleClass="feature-icon"/>
                <Label text="Accédez à une bibliothèque curatée" styleClass="feature-item"/>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="🌟" styleClass="feature-icon"/>
                <Label text="Connectez-vous avec la communauté créative" styleClass="feature-item"/>
            </HBox>
        </VBox>
    </VBox>

    <!-- ═══════════════════════════════════════════════════════
         RIGHT PANEL — Registration Form
    ═══════════════════════════════════════════════════════════ -->
    <VBox styleClass="signup-right" alignment="TOP_CENTER" HBox.hgrow="ALWAYS">

        <!-- ─── Top navigation bar ─── -->
        <HBox styleClass="signup-topnav" alignment="CENTER_RIGHT" spacing="8">
            <padding>
                <Insets top="14" right="24" bottom="10" left="24"/>
            </padding>
            <Label text="ARTIUM" styleClass="topnav-brand"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Accueil" onAction="#onHomeClick" styleClass="topnav-link"/>
            <Button text="Connexion" onAction="#onLoginLink" styleClass="topnav-btn-outline"/>
            <Button text="S'inscrire" styleClass="topnav-btn-filled" disable="true"/>
        </HBox>

        <!-- ─── Scrollable form card ─── -->
        <ScrollPane fitToWidth="true" styleClass="signup-scroll" VBox.vgrow="ALWAYS">
            <VBox styleClass="signup-card" spacing="14" maxWidth="500" minWidth="360">
                <padding>
                    <Insets top="32" right="40" bottom="32" left="40"/>
                </padding>

                <Label text="Créer un compte" styleClass="form-title"/>
                <Label text="Rejoignez Artium gratuitement dès aujourd'hui !" styleClass="form-subtitle"/>

                <!-- First Name / Last Name -->
                <HBox spacing="14">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Prénom *" styleClass="field-label"/>
                        <TextField fx:id="firstNameField" promptText="Votre prénom" styleClass="form-field"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Nom *" styleClass="field-label"/>
                        <TextField fx:id="lastNameField" promptText="Votre nom" styleClass="form-field"/>
                    </VBox>
                </HBox>

                <!-- Email -->
                <VBox spacing="5">
                    <Label text="Adresse e-mail *" styleClass="field-label"/>
                    <TextField fx:id="emailField" promptText="vous@exemple.com" styleClass="form-field"/>
                </VBox>

                <!-- Date of Birth -->
                <VBox spacing="5">
                    <Label text="Date de naissance *" styleClass="field-label"/>
                    <DatePicker fx:id="dobPicker" promptText="jj/mm/aaaa" styleClass="form-field" maxWidth="1.7976931348623157E308"/>
                </VBox>

                <!-- Password -->
                <VBox spacing="5">
                    <Label text="Mot de passe *" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField" promptText="Au moins 6 caractères" styleClass="form-field"/>
                </VBox>

                <!-- Confirm Password -->
                <VBox spacing="5">
                    <Label text="Confirmer le mot de passe *" styleClass="field-label"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Répétez votre mot de passe" styleClass="form-field"/>
                </VBox>

                <!-- Role selector -->
                <VBox spacing="8">
                    <Label text="S'inscrire en tant que" styleClass="field-label"/>
                    <HBox spacing="10">
                        <RadioButton text="Amateur" styleClass="role-radio"
                                     toggleGroup="$roleGroup" selected="true"
                                     userData="ROLE_AMATEUR"/>
                        <RadioButton text="Artiste" styleClass="role-radio"
                                     toggleGroup="$roleGroup"
                                     userData="ROLE_ARTIST"/>
                    </HBox>
                </VBox>

                <!-- Feedback label (error / success) -->
                <Label fx:id="errorLabel" text="" wrapText="true" styleClass="feedback-label"/>

                <!-- Sign Up button -->
                <Button text="S'inscrire" onAction="#onSignUp"
                        styleClass="signup-btn" maxWidth="1.7976931348623157E308"/>

                <!-- Login link -->
                <HBox alignment="CENTER" spacing="4">
                    <Label text="Déjà un compte ?" styleClass="login-prompt"/>
                    <Button text="Se connecter" onAction="#onLoginLink" styleClass="login-link"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </VBox>

</HBox>
