<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="25.0" style="-fx-background-color: #f3f4f6;" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
    
    <VBox alignment="CENTER" spacing="10.0">
        <Label text="Artium" textFill="#3b82f6">
            <font>
                <Font name="System Bold" size="48.0" />
            </font>
        </Label>
        <Label text="Connectez-vous à votre espace" textFill="#6b7280">
            <font>
                <Font size="16.0" />
            </font>
        </Label>
    </VBox>

    <VBox maxWidth="400.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
        </padding>
        
        <VBox spacing="8.0">
            <Label text="Email" textFill="#374151">
                <font>
                    <Font name="System Bold" size="14.0" />
                </font>
            </Label>
            <TextField fx:id="emailField" prefHeight="45.0" promptText="votre@email.com" style="-fx-background-radius: 8; -fx-border-color: #d1d5db; -fx-border-radius: 8; -fx-background-color: white;" />
        </VBox>
        
        <VBox spacing="8.0">
            <Label text="Mot de passe" textFill="#374151">
                <font>
                    <Font name="System Bold" size="14.0" />
                </font>
            </Label>
            <PasswordField fx:id="passwordField" prefHeight="45.0" promptText="••••••••" style="-fx-background-radius: 8; -fx-border-color: #d1d5db; -fx-border-radius: 8; -fx-background-color: white;" />
        </VBox>
        
        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onLogin" prefHeight="45.0" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;" text="Se connecter">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Button>
    </VBox>
    
    <HBox alignment="CENTER" spacing="5.0">
        <Label text="Pas encore de compte ?" textFill="#6b7280" />
        <Label text="Inscrivez-vous" textFill="#3b82f6" style="-fx-cursor: hand; -fx-font-weight: bold;" />
    </HBox>
</VBox>
