<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="auth-root" stylesheets="@../styles/auth.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/20.0.2" fx:controller="controllers.AuthLandingController">
	<top>
		<HBox alignment="CENTER_LEFT" spacing="12" styleClass="auth-topbar auth-topbar-glass">
			<padding>
				<Insets bottom="14" left="18" right="18" top="14" />
			</padding>
			<StackPane styleClass="auth-mini-logo-wrap">
				<ImageView cache="true" fitWidth="112" preserveRatio="true" smooth="true" styleClass="auth-mini-logo">
					<image>
						<Image url="@../images/logo2.png" />
					</image>
				</ImageView>
			</StackPane>
			<Region HBox.hgrow="ALWAYS" />
			<Button onAction="#onLoginClick" styleClass="auth-topbar-ghost" text="Se connecter" />
			<Button onAction="#onCreateAccount" styleClass="auth-topbar-primary" text="Créer un compte" />
		</HBox>
	</top>

	<center>
		<StackPane styleClass="auth-landing-shell auth-landing-shell-fluid">
			<HBox alignment="CENTER" spacing="0" styleClass="auth-landing-card auth-landing-card-fluid">
				<VBox alignment="CENTER_LEFT" maxWidth="Infinity" prefWidth="565" spacing="20" styleClass="auth-landing-hero auth-landing-hero-fluid" HBox.hgrow="ALWAYS">
					<padding>
						<Insets bottom="48" left="48" right="48" top="48" />
					</padding>
					<StackPane styleClass="auth-hero-logo-wrap">
						<ImageView cache="true" fitWidth="250" preserveRatio="true" smooth="true" styleClass="auth-hero-logo">
							<image>
								<Image url="@../images/logo2.png" />
							</image>
						</ImageView>
					</StackPane>
					<Label styleClass="auth-panel-kicker" text="Plateforme artistique" />
					<Label styleClass="auth-hero-title auth-landing-title" text="Donnez vie a votre univers creatif" wrapText="true" />
					<Label styleClass="auth-hero-text auth-landing-text" text="Explorez un espace où la créativité s’exprime librement, où chaque œuvre reflète une vision unique et où l’art prend vie à travers des styles modernes et inspirants." wrapText="true" />
					<HBox spacing="10" styleClass="auth-chip-row">
						<Label styleClass="auth-chip" text="Rapide" />
						<Label styleClass="auth-chip" text="Sécurisé" />
						<Label styleClass="auth-chip" text="Moderne" />
					</HBox>
				</VBox>

				<VBox alignment="CENTER_LEFT" maxWidth="Infinity" prefWidth="565" spacing="16" styleClass="auth-landing-panel auth-landing-panel-fluid auth-panel-block" HBox.hgrow="ALWAYS">
					<padding>
						<Insets bottom="48" left="44" right="44" top="48" />
					</padding>
					<Label styleClass="auth-panel-kicker" text="Bienvenue" />
					<Label styleClass="auth-panel-title auth-landing-panel-title" text="Commencez votre inscription" wrapText="true" />
					<Label styleClass="auth-panel-text auth-landing-panel-text" text="Créez votre profil et accédez à une interface intuitive, optimisée pour amateur, artiste ou admin." wrapText="true" />
					<VBox spacing="12" styleClass="auth-landing-actions">
						<Button maxWidth="Infinity" onAction="#onCreateAccount" styleClass="auth-primary-button" text="Créer mon compte" />
						<Button maxWidth="Infinity" onAction="#onLoginClick" styleClass="auth-secondary-button" text="J'ai déjà un compte" />
					</VBox>
				</VBox>
			</HBox>
		</StackPane>
	</center>
</BorderPane>
